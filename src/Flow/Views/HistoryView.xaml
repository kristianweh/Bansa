<UserControl x:Class="Flow.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="History" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,16"
                   Text="Total bandwidth used per app over a selected time range." />

        <!-- Filter row -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Today"      Click="OnPresetToday"   Margin="0,0,6,0" />
                <Button Content="Last 7 d"   Click="OnPreset7"       Margin="0,0,6,0" />
                <Button Content="Last 30 d"  Click="OnPreset30"      Margin="0,0,18,0" />

                <TextBlock Text="From" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,6,0" />
                <DatePicker x:Name="FromPicker" />
                <TextBlock Text="to" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" Margin="10,0,6,0" />
                <DatePicker x:Name="ToPicker" />
                <Button Content="Apply" Style="{StaticResource AccentButton}" Margin="10,0,0,0" Click="OnApply" />
                <Button Content="Export CSV…" Margin="12,0,0,0" Click="OnExportCsv" />
            </StackPanel>
        </Border>

        <!-- Totals + list + activity log -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" MinHeight="80" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" MinHeight="140" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL DOWN" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TotalDownText" Text="—" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ChartDownBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL UP" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TotalUpText" Text="—" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ChartUpBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="RANGE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="RangeText" Text="—" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,0">
                <DataGrid x:Name="HistoryGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True" SelectionMode="Single"
                          RowHeight="32">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="App"      Binding="{Binding Name}"      SortMemberPath="Name" Width="*" />
                        <DataGridTextColumn Header="Total ↓"  Binding="{Binding DownText}"  SortMemberPath="BytesIn"  Width="180" />
                        <DataGridTextColumn Header="Total ↑"  Binding="{Binding UpText}"    SortMemberPath="BytesOut" Width="180" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Activity log header -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,8">
                <TextBlock Text="Activity Log" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text=" — blocks, limits, and priority changes" FontSize="12"
                           Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Activity log list -->
            <Border Grid.Row="3" Style="{StaticResource Card}" ClipToBounds="False">
                <DataGrid x:Name="ActivityGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True" SelectionMode="Single"
                          RowHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"    Binding="{Binding TimeText}"   Width="160" />
                        <DataGridTextColumn Header="App"     Binding="{Binding App}"        Width="*" />
                        <DataGridTextColumn Header="Action"  Binding="{Binding ActionText}" Width="160" />
                        <DataGridTextColumn Header="Details" Binding="{Binding DetailText}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
