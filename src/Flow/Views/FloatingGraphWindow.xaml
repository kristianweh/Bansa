<Window x:Class="Flow.Views.FloatingGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Flow Graph"
        WindowStyle="None"
        Background="{DynamicResource BgBrush}"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        MinWidth="180" MinHeight="120"
        Width="340" Height="500">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="30"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Pill toggle — Carbon palette, gradient checked state -->
        <Style x:Key="PillTab" TargetType="ToggleButton">
            <Setter Property="Background"      Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground"      Value="{DynamicResource SubtleTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="12,5" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontFamily"      Value="{StaticResource RobotoFamily}" />
            <Setter Property="FontSize"        Value="10" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentGradientBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal icon button -->
        <Style x:Key="MiniBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{DynamicResource SubtleTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentGradientBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section grip line (GridSplitter visual) -->
        <Style x:Key="SectionGrip" TargetType="GridSplitter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment"   Value="Center" />
            <Setter Property="Height"              Value="5" />
            <Setter Property="Background"          Value="Transparent" />
            <Setter Property="Cursor"              Value="SizeNS" />
            <Setter Property="ResizeDirection"     Value="Rows" />
            <Setter Property="ResizeBehavior"      Value="PreviousAndNext" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Rectangle Height="2" Width="28" Fill="{DynamicResource BorderBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RadiusX="1" RadiusY="1" Opacity="0.7" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="ContentGrid" Background="{DynamicResource BgBrush}"
          ContextMenuOpening="OnWindowContextMenuOpening">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="AlwaysOnTopMenu" Header="Always on top"
                          IsCheckable="True" IsChecked="True"
                          Click="OnAlwaysOnTopMenuClick" />
                <Separator />
                <MenuItem x:Name="ShowSystemMenu" Header="Show system info"
                          IsCheckable="True" IsChecked="True"
                          Click="OnShowSystemMenuClick" />
            </ContextMenu>
        </Grid.ContextMenu>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition x:Name="GraphRow" Height="3*" MinHeight="80" />
            <RowDefinition x:Name="S1Row"    Height="8" />
            <RowDefinition x:Name="AppsRow"  Height="2*" MinHeight="0" />
            <RowDefinition x:Name="S2Row"    Height="8" />
            <RowDefinition x:Name="HwRow"    Height="0" MinHeight="0" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER — compact 30 px bar ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="8,0,4,0">
                <!-- Brand -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
                    <Border Width="3" CornerRadius="2" Margin="0,6,7,6"
                            Background="{DynamicResource AccentGradientVerticalBrush}" />
                    <TextBlock Text="FLOW" VerticalAlignment="Center"
                               FontFamily="{StaticResource RobotoMonoFamily}" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" />
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <ToggleButton x:Name="PinBtn" Style="{StaticResource MiniToggleBtn}"
                                  Width="26" Height="26" Margin="0,0,2,0"
                                  IsChecked="True" ToolTip="Always on top"
                                  Checked="OnPinChanged" Unchecked="OnPinChanged">
                        <TextBlock Text="&#xE718;" />
                    </ToggleButton>
                    <Button Style="{StaticResource MiniBtn}" Width="26" Height="26"
                            ToolTip="Close" Click="OnCloseClick">
                        <TextBlock Text="&#xE8BB;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ GRAPH + RATES + PING ═══ -->
        <Grid Grid.Row="1" x:Name="GraphSection">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />    <!-- rates strip — auto so Roboto Mono never clips -->
                <RowDefinition Height="Auto" />    <!-- ping strip  — auto -->
            </Grid.RowDefinitions>

            <Canvas x:Name="ChartCanvas" Grid.Row="0" ClipToBounds="True" Margin="6,4,6,0" />
            <Canvas x:Name="FloatChartOverlay" Grid.Row="0" ClipToBounds="True"
                    Margin="6,4,6,0" Background="Transparent"
                    MouseMove="OnFloatChartMouseMove"
                    MouseLeave="OnFloatChartMouseLeave" />

            <!-- Peak labels -->
            <TextBlock x:Name="DownPeakLabel" Grid.Row="0"
                       FontSize="9" FontWeight="SemiBold"
                       Foreground="{DynamicResource ChartDownBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       Margin="9,5,0,0" IsHitTestVisible="False" />
            <TextBlock x:Name="UpPeakLabel" Grid.Row="0"
                       FontSize="9" FontWeight="SemiBold"
                       Foreground="{DynamicResource ChartUpBrush}"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,5,9,0" IsHitTestVisible="False" />
            <TextBlock Text="60 s" Grid.Row="0" FontSize="9"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,9,3" IsHitTestVisible="False" />

            <!-- Rates strip — Padding="10,9": CornerRadius=10 clips the last 10px at corners,
                 so 9px vertical padding keeps text clear of the clip boundary -->
            <Border Grid.Row="1"
                    Background="{DynamicResource PanelAltBrush}"
                    CornerRadius="10" Margin="6,4,6,2" Padding="10,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Download: arrow + large number + small unit -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="↓ " FontSize="15" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartDownBrush}" />
                        <TextBlock x:Name="DownRateValue" Text="—" FontSize="15" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartDownBrush}">
                            <TextBlock.LayoutTransform><ScaleTransform ScaleX="0.90"/></TextBlock.LayoutTransform>
                        </TextBlock>
                        <TextBlock x:Name="DownRateUnit" Text="" FontSize="10" FontWeight="Medium"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartDownBrush}"
                                   VerticalAlignment="Bottom" Margin="2,0,0,3">
                            <TextBlock.LayoutTransform><ScaleTransform ScaleX="0.90"/></TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>

                    <!-- Upload: large number + small unit + arrow — wrapped for Visibility toggling -->
                    <StackPanel x:Name="UpRatePanel" Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="UpRateValue" Text="—" FontSize="15" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartUpBrush}">
                            <TextBlock.LayoutTransform><ScaleTransform ScaleX="0.90"/></TextBlock.LayoutTransform>
                        </TextBlock>
                        <TextBlock x:Name="UpRateUnit" Text="" FontSize="10" FontWeight="Medium"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartUpBrush}"
                                   VerticalAlignment="Bottom" Margin="2,0,0,3">
                            <TextBlock.LayoutTransform><ScaleTransform ScaleX="0.90"/></TextBlock.LayoutTransform>
                        </TextBlock>
                        <TextBlock Text=" ↑" FontSize="15" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartUpBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Ping strip — same clearance logic as rates strip above -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PanelAltBrush}"
                    CornerRadius="10" Margin="6,2,6,4" Padding="10,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="PingDot" Grid.Column="0" Width="7" Height="7"
                             Fill="{DynamicResource SubtleTextBrush}"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Grid.Column="1" Text="PING"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="PingTargetLabel" Grid.Column="2"
                               FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"
                               Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,6,0">
                        <TextBlock x:Name="PingText" Text="—"
                                   FontSize="17" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock x:Name="FloatPingUnit" Text="ms"
                                   FontSize="10" FontWeight="Medium"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Bottom" Margin="3,0,0,3" />
                    </StackPanel>
                    <TextBlock x:Name="PingJitterText" Grid.Column="4"
                               Text="" FontSize="9" FontFamily="{StaticResource RobotoMonoFamily}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="2" x:Name="Splitter1" Style="{StaticResource SectionGrip}" />

        <!-- ═══ APPS SECTION ═══ -->
        <Border Grid.Row="3" x:Name="AppsSection" Background="{DynamicResource BgBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="8,6,8,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="TOP APPS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Grid.Column="1" Text="↓ DOWN" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChartDownBrush}" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="2" Text="↑ UP" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChartUpBrush}" HorizontalAlignment="Right" />
                </Grid>

                <ItemsControl x:Name="TopAppsList" Grid.Row="1" Margin="6,0,6,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="26" Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Image Source="{Binding Icon}" Width="14" Height="14"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontSize="11"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DownRate, Mode=OneWay, Converter={StaticResource SpeedValue}}"
                                               FontSize="11" FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartDownBrush}" />
                                    <TextBlock Text="{Binding DownRate, Mode=OneWay, Converter={StaticResource SpeedUnit}}"
                                               FontSize="8" FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartDownBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,1" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UpRate, Mode=OneWay, Converter={StaticResource SpeedValue}}"
                                               FontSize="11" FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartUpBrush}" />
                                    <TextBlock Text="{Binding UpRate, Mode=OneWay, Converter={StaticResource SpeedUnit}}"
                                               FontSize="8" FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartUpBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,1" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="4" x:Name="Splitter2" Style="{StaticResource SectionGrip}" />

        <!-- ═══ HARDWARE SECTION ═══ -->
        <Border Grid.Row="5" x:Name="HwSection"
                Background="{DynamicResource BgBrush}" Visibility="Collapsed">
            <Grid Margin="8,6,8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="SYSTEM" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,6" />

                <Grid Grid.Row="1" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- CPU box -->
                    <Border Grid.Column="0" Background="{DynamicResource PanelAltBrush}"
                            CornerRadius="10" Padding="10,8" MinHeight="80">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="CPU" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,2" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="0,2,0,2">
                                <TextBlock x:Name="CpuTempFloat" Text="—"
                                           FontSize="28" FontWeight="Bold"
                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Padding="0,4" />
                                <TextBlock Text="°" FontSize="14" FontWeight="Bold"
                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,6" />
                            </StackPanel>
                            <Border Grid.Row="2" x:Name="CpuBarBg"
                                    Background="{DynamicResource BgBrush}"
                                    CornerRadius="2" Height="3" Margin="0,0,0,4">
                                <Border x:Name="CpuBarFill" CornerRadius="2"
                                        HorizontalAlignment="Left" Height="3" Width="0"
                                        Background="{DynamicResource AccentGradientBrush}" />
                            </Border>
                            <TextBlock Grid.Row="3" x:Name="CpuStatsText" FontSize="10"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>

                    <!-- GPU box -->
                    <Border Grid.Column="2" x:Name="GpuRow"
                            Background="{DynamicResource PanelAltBrush}"
                            CornerRadius="10" Padding="10,8" MinHeight="80">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="GPU" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,2" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="0,2,0,2">
                                <TextBlock x:Name="GpuTempFloat" Text="—"
                                           FontSize="28" FontWeight="Bold"
                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                           Foreground="{DynamicResource ChartUpBrush}"
                                           Padding="0,4" />
                                <TextBlock Text="°" FontSize="14" FontWeight="Bold"
                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                           Foreground="{DynamicResource ChartUpBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,6" />
                            </StackPanel>
                            <Border Grid.Row="2" x:Name="GpuBarBg"
                                    Background="{DynamicResource BgBrush}"
                                    CornerRadius="2" Height="3" Margin="0,0,0,4">
                                <Border x:Name="GpuBarFill" CornerRadius="2"
                                        HorizontalAlignment="Left" Height="3" Width="0"
                                        Background="{DynamicResource ChartUpBrush}" />
                            </Border>
                            <TextBlock Grid.Row="3" x:Name="GpuStatsText" FontSize="10"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <Grid Grid.Row="4" x:Name="VramRow" Margin="0,4,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="VramBarBg" Background="{DynamicResource BgBrush}"
                                        CornerRadius="2" Height="3" VerticalAlignment="Center">
                                    <Border x:Name="VramBarFill" CornerRadius="2"
                                            HorizontalAlignment="Left" Height="3" Width="0"
                                            Background="#CC8833" />
                                </Border>
                                <TextBlock x:Name="VramStatsText" Grid.Column="1"
                                           FontSize="9" Foreground="{DynamicResource SubtleTextBrush}"
                                           Margin="5,0,0,0" VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- RAM strip -->
                <Border Grid.Row="2" Background="{DynamicResource PanelAltBrush}"
                        CornerRadius="10" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RAM" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                        <Border Grid.Column="1" x:Name="RamBarBg"
                                Background="{DynamicResource BgBrush}"
                                CornerRadius="2" Height="3" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Border x:Name="RamBarFill" CornerRadius="2"
                                    HorizontalAlignment="Left" Height="3" Width="0"
                                    Background="{DynamicResource SuccessBrush}" />
                        </Border>
                        <TextBlock x:Name="RamStatsText" Grid.Column="2" FontSize="10"
                                   Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
