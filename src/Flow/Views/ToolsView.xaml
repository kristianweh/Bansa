<UserControl x:Class="Flow.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Flow.ViewModels">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,8,24,24" MaxWidth="860" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Tools" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Portable utilities — downloaded once into your Flow folder."
                       Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,20" />

            <!-- Tool cards -->
            <ItemsControl ItemsSource="{Binding Tools}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PortableToolItem}">
                        <Border Padding="16,14" Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}" />
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon badge -->
                                <Border Grid.Column="0"
                                        Width="38" Height="38" CornerRadius="8"
                                        Background="{DynamicResource PanelAltBrush}"
                                        VerticalAlignment="Top" Margin="0,1,0,0">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="18"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <!-- Name / description / progress -->
                                <StackPanel Grid.Column="1" Margin="12,0,16,0" VerticalAlignment="Center">

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Margin="0,0,0,3" />

                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,0,0,6" />

                                    <!-- Progress bar + status (visible while downloading) -->
                                    <StackPanel Margin="0,0,0,2">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   Margin="0,0,0,5" />

                                        <!-- Track -->
                                        <Border Background="{DynamicResource PanelAltBrush}"
                                                CornerRadius="3" Height="5"
                                                MaxWidth="320" HorizontalAlignment="Left">
                                            <!-- Fill -->
                                            <Border Background="{DynamicResource AccentBrush}"
                                                    HorizontalAlignment="Left"
                                                    Height="5" CornerRadius="3">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                                        <Binding Path="Progress" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}"
                                                                 Path="ActualWidth" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Border>
                                    </StackPanel>

                                    <!-- Sub-label (idle) -->
                                    <TextBlock Text="{Binding SubLabel}"
                                               FontSize="11" Opacity="0.45"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Error message -->
                                    <TextBlock Text="{Binding Error}"
                                               Foreground="#EF5350"
                                               FontSize="11" TextWrapping="Wrap"
                                               Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Error}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </StackPanel>

                                <!-- Buttons (right side) -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">

                                    <!-- Action button (Download / Open / Run) — hidden while downloading -->
                                    <Button Padding="18,8" Command="{Binding ActionCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding ButtonLabel}" />
                                    </Button>

                                    <!-- Cancel button — visible only while downloading -->
                                    <Button Content="Cancel" Padding="18,8"
                                            Command="{Binding CancelCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
