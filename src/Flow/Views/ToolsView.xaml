<UserControl x:Class="Flow.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Flow.ViewModels">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,8,24,24">

            <!-- Header -->
            <TextBlock Text="Tools" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Portable utilities — downloaded once into your Flow folder."
                       Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,20" />

            <!-- Card grid -->
            <ItemsControl ItemsSource="{Binding Tools}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PortableToolItem}">

                        <!-- Tool card — 210 px wide -->
                        <Border Width="210" Margin="0,0,12,12" CornerRadius="10"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="96" />   <!-- coloured tile  -->
                                    <RowDefinition Height="*"  />   <!-- content        -->
                                </Grid.RowDefinitions>

                                <!-- ── Coloured logo tile ── -->
                                <Border Grid.Row="0"
                                        Background="{Binding TileBrush}"
                                        CornerRadius="9,9,0,0">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="44"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Opacity="0.92" />
                                </Border>

                                <!-- ── Card body ── -->
                                <StackPanel Grid.Row="1" Margin="14,12,14,14">

                                    <!-- Name -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="0,0,0,4" />

                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11.5"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="16"
                                               Margin="0,0,0,10" />

                                    <!-- ── Downloading state ── -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />

                                        <!-- Progress track -->
                                        <Border Background="{DynamicResource PanelAltBrush}"
                                                CornerRadius="3" Height="5"
                                                Margin="0,0,0,8">
                                            <Border Background="{Binding TileBrush}"
                                                    HorizontalAlignment="Left"
                                                    Height="5" CornerRadius="3">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                                        <Binding Path="Progress" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}"
                                                                 Path="ActualWidth" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Border>

                                        <Button Content="Cancel" Padding="0,7"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding CancelCommand}" />
                                    </StackPanel>

                                    <!-- ── Idle state ── -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!-- Status dot + sub-label -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                <Setter Property="Fill" Value="#4CAF50" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsScript}" Value="True">
                                                                <Setter Property="Fill" Value="#FF9800" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding SubLabel}"
                                                       FontSize="10.5"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Error -->
                                        <TextBlock Text="{Binding Error}"
                                                   Foreground="#EF5350"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Margin="0,0,0,8">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Error}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Action button -->
                                        <Button Padding="0,8"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding ActionCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}" />
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding ButtonLabel}"
                                                           FontSize="12" FontWeight="Medium" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                </StackPanel>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
