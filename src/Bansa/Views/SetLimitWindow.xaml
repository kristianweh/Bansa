<Window x:Class="Bansa.Views.SetLimitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set bandwidth limit"
        SizeToContent="Height"
        Width="520" MinWidth="460" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource BgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App title with gradient accent bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <Border Width="4" CornerRadius="2" Margin="0,2,10,2"
                    Background="{DynamicResource AccentGradientVerticalBrush}" />
            <TextBlock x:Name="AppNameText" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Upload limit -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="↑" FontSize="16" Foreground="{DynamicResource ChartUpBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="Upload limit" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                    </StackPanel>
                    <CheckBox x:Name="UploadEnabled" Grid.Column="1"
                              Content="Enabled"
                              Foreground="{DynamicResource SubtleTextBrush}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBox x:Name="UploadKbpsBox" Width="120" Text="1000" />
                    <TextBlock Text="KB/s" VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="{DynamicResource SubtleTextBrush}" />
                </StackPanel>
                <!-- Presets generated in code-behind based on connection speed -->
                <WrapPanel x:Name="UploadPresetsPanel" Orientation="Horizontal" Margin="0,8,0,0" />
                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                           Text="Enforced by Windows QoS — smooth kernel-level rate shaping, no dropped connections. QoS caps a connection when it opens, so an already-open connection stays uncapped until it reconnects; the app's ↑ badge turns amber while it's still over the cap." />
                <!-- UDP warning — shown when the app has active UDP connections -->
                <Border x:Name="UdpWarningBorder" Visibility="Collapsed"
                        Background="#22F59E0B" BorderBrush="#55F59E0B" BorderThickness="1"
                        CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x26A0;" FontSize="14" Foreground="#F59E0B"
                                   Margin="0,0,8,0" VerticalAlignment="Top" />
                        <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="11" Foreground="#F59E0B">
                            <Run FontWeight="SemiBold" Text="UDP traffic detected. " />
                            <Run Text="This app has active UDP connections (voice, game packets, QUIC). QoS shapes UDP on newly-opened sockets, but QUIC often keeps reusing one long-lived connection that the cap can't reach until the app reconnects — so the limit may not bite right away. TCP throttles cleanly." />
                        </TextBlock>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Download limit -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="↓" FontSize="16" Foreground="{DynamicResource ChartDownBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="Download limit" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                    </StackPanel>
                    <CheckBox x:Name="DownloadEnabled" Grid.Column="1"
                              Content="Enabled"
                              Foreground="{DynamicResource SubtleTextBrush}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBox x:Name="DownloadKbpsBox" Width="120" Text="1000" />
                    <TextBlock Text="KB/s" VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="{DynamicResource SubtleTextBrush}" />
                </StackPanel>
                <!-- Presets generated in code-behind based on connection speed -->
                <WrapPanel x:Name="DownloadPresetsPanel" Orientation="Horizontal" Margin="0,8,0,0" />
                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                           Text="Best-effort cap — Windows has no user-mode inbound rate limiter (that requires a kernel driver). Bansa pulses a firewall block at 10 Hz to keep the average at the target. Burst-sensitive apps (video calls, games) may see brief interruptions." />
            </StackPanel>
        </Border>

        <!-- Profiles quick-apply (hidden when no profiles exist) -->
        <Border Grid.Row="3" x:Name="ProfilesCard" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Load profile" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" />
                <WrapPanel x:Name="ProfilesPanel" Orientation="Horizontal" />
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Click="OnCancel" Padding="16,8" MinWidth="100" Margin="0,0,8,0" />
            <Button Content="Apply"  Click="OnApply"  Padding="16,8" MinWidth="100" Style="{StaticResource AccentButton}" />
        </StackPanel>
    </Grid>
</Window>
