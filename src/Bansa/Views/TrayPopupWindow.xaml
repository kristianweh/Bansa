<Window x:Class="Bansa.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="460" Height="490"
        Focusable="False"
        ShowActivated="False"
        Opacity="0">

    <Window.Resources>
        <!-- Compact icon toggle — pin / click-through -->
        <Style x:Key="TrayIconToggle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentGradientBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer container — Carbon palette: CornerRadius 14, stronger shadow -->
    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="16"
            MouseLeftButtonDown="OnPopupDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" Direction="270" ShadowDepth="4" Opacity="0.50" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- live totals + ping + toggles -->
                <RowDefinition Height="Auto" />  <!-- daily totals -->
                <RowDefinition Height="Auto" />  <!-- divider -->
                <RowDefinition Height="110" />   <!-- chart -->
                <RowDefinition Height="Auto" />  <!-- divider -->
                <RowDefinition Height="Auto" />  <!-- hardware strip -->
                <RowDefinition Height="Auto" />  <!-- divider -->
                <RowDefinition Height="Auto" />  <!-- top apps header -->
                <RowDefinition Height="*" />     <!-- top apps list -->
            </Grid.RowDefinitions>

            <!-- ── Live totals ── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DOWN" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChartDownBrush}" Margin="0,0,0,1" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TotalDown" Text="0" FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartDownBrush}" />
                        <TextBlock x:Name="TotalDownUnit" Text="B/s" FontSize="11" FontWeight="Medium"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartDownBrush}"
                                   VerticalAlignment="Bottom" Margin="3,0,0,3" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="UP" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChartUpBrush}" Margin="0,0,0,1" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TotalUp" Text="0" FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartUpBrush}" />
                        <TextBlock x:Name="TotalUpUnit" Text="B/s" FontSize="11" FontWeight="Medium"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource ChartUpBrush}"
                                   VerticalAlignment="Bottom" Margin="3,0,0,3" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="PingLabel" Text="PING" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,1" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="PingText" Text="—" FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock x:Name="PingUnit" Text="ms" FontSize="11" FontWeight="Medium"
                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Bottom" Margin="3,0,0,3" />
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="TrayTogglePanel" Grid.Column="3" Orientation="Vertical"
                            VerticalAlignment="Center" Margin="10,0,0,0">
                    <ToggleButton x:Name="TrayPinBtn"
                                  Style="{StaticResource TrayIconToggle}"
                                  Width="26" Height="26" Margin="0,0,0,3"
                                  IsChecked="True"
                                  ToolTip="Always on top"
                                  Click="OnTrayPinClick">
                        <TextBlock Text="&#xE718;" />
                    </ToggleButton>
                    <ToggleButton x:Name="TrayClickThroughBtn"
                                  Style="{StaticResource TrayIconToggle}"
                                  Width="26" Height="26"
                                  IsChecked="False"
                                  ToolTip="Click-through — mouse events pass to windows below"
                                  Click="OnTrayClickThroughClick">
                        <TextBlock Text="&#xE748;" />
                    </ToggleButton>
                </StackPanel>
            </Grid>

            <!-- ── Daily totals ── -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource PanelAltBrush}"
                        CornerRadius="10" Padding="10,7" Margin="0,0,4,0">
                    <StackPanel>
                        <TextBlock Text="TODAY ↓" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ChartDownBrush}" Margin="0,0,0,1" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="DayDown" Text="—" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                       Foreground="{DynamicResource ChartDownBrush}" />
                            <TextBlock x:Name="DayDownUnit" Text="" FontSize="10"
                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                       Foreground="{DynamicResource ChartDownBrush}"
                                       VerticalAlignment="Bottom" Margin="3,0,0,2" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource PanelAltBrush}"
                        CornerRadius="10" Padding="10,7" Margin="4,0,0,0">
                    <StackPanel>
                        <TextBlock Text="TODAY ↑" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ChartUpBrush}" Margin="0,0,0,1" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="DayUp" Text="—" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                       Foreground="{DynamicResource ChartUpBrush}" />
                            <TextBlock x:Name="DayUpUnit" Text="" FontSize="10"
                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                       Foreground="{DynamicResource ChartUpBrush}"
                                       VerticalAlignment="Bottom" Margin="3,0,0,2" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Divider -->
            <Border Grid.Row="2" Background="{DynamicResource BorderBrush}"
                    Height="1" Margin="0,12,0,8" />

            <!-- ── Chart ── -->
            <Grid Grid.Row="3">
                <Border CornerRadius="10" Background="{DynamicResource PanelAltBrush}" />
                <Canvas x:Name="ChartCanvas" ClipToBounds="True" />
                <TextBlock x:Name="ChartPeakLabel" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,4,0,0" />
                <TextBlock Text="30 s" FontSize="10"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,8,0" />
            </Grid>

            <!-- Divider -->
            <Border Grid.Row="4" Background="{DynamicResource BorderBrush}"
                    Height="1" Margin="0,10,0,8" />

            <!-- ── Hardware strip ── -->
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource PanelAltBrush}"
                        CornerRadius="8" Padding="8,7">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                            <TextBlock x:Name="TrayHwCpuPct" Grid.Column="2"
                                       Text="—" FontSize="11" FontWeight="Bold"
                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                       Foreground="{DynamicResource AccentBrush}" Padding="0,2" />
                        </Grid>
                        <Border x:Name="TrayHwCpuBarBg" Background="{DynamicResource BgBrush}"
                                CornerRadius="2" Height="3" Margin="0,4,0,3">
                            <Border x:Name="TrayHwCpuBarFill" CornerRadius="2"
                                    HorizontalAlignment="Left" Height="3" Width="0"
                                    Background="{DynamicResource ChartCpuBrush}" />
                        </Border>
                        <TextBlock x:Name="TrayHwCpuDetail" Text="" FontSize="9"
                                   Foreground="{DynamicResource SubtleTextBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource PanelAltBrush}"
                        CornerRadius="8" Padding="8,7">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GPU" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                            <TextBlock x:Name="TrayHwGpuPct" Grid.Column="2"
                                       Text="—" FontSize="11" FontWeight="Bold"
                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                       Foreground="{DynamicResource ChartGpuBrush}" Padding="0,2" />
                        </Grid>
                        <Border x:Name="TrayHwGpuBarBg" Background="{DynamicResource BgBrush}"
                                CornerRadius="2" Height="3" Margin="0,4,0,3">
                            <Border x:Name="TrayHwGpuBarFill" CornerRadius="2"
                                    HorizontalAlignment="Left" Height="3" Width="0"
                                    Background="{DynamicResource ChartGpuBrush}" />
                        </Border>
                        <TextBlock x:Name="TrayHwGpuDetail" Text="" FontSize="9"
                                   Foreground="{DynamicResource SubtleTextBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="{DynamicResource PanelAltBrush}"
                        CornerRadius="8" Padding="8,7">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RAM" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                            <TextBlock x:Name="TrayHwRamPct" Grid.Column="2"
                                       Text="—" FontSize="11" FontWeight="Bold"
                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                       Foreground="{DynamicResource SuccessBrush}" Padding="0,2" />
                        </Grid>
                        <Border x:Name="TrayHwRamBarBg" Background="{DynamicResource BgBrush}"
                                CornerRadius="2" Height="3" Margin="0,4,0,3">
                            <Border x:Name="TrayHwRamBarFill" CornerRadius="2"
                                    HorizontalAlignment="Left" Height="3" Width="0"
                                    Background="{DynamicResource SuccessBrush}" />
                        </Border>
                        <TextBlock x:Name="TrayHwRamDetail" Text="" FontSize="9"
                                   Foreground="{DynamicResource SubtleTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Divider -->
            <Border Grid.Row="6" Background="{DynamicResource BorderBrush}"
                    Height="1" Margin="0,10,0,8" />

            <!-- ── Top apps header ── -->
            <Grid Grid.Row="7" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TOP APPS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <TextBlock Grid.Column="1" Text="↓ Down" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource ChartDownBrush}" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="2" Text="↑ Up" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource ChartUpBrush}" HorizontalAlignment="Right" />
            </Grid>

            <!-- ── Top apps list ── -->
            <ItemsControl Grid.Row="8" x:Name="TopAppsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3,0,3" Height="26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DownRate, Mode=OneWay, Converter={StaticResource SpeedValue}}"
                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                           Foreground="{DynamicResource ChartDownBrush}" />
                                <TextBlock Text="{Binding DownRate, Mode=OneWay, Converter={StaticResource SpeedUnit}}"
                                           FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                           Foreground="{DynamicResource ChartDownBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UpRate, Mode=OneWay, Converter={StaticResource SpeedValue}}"
                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                           Foreground="{DynamicResource ChartUpBrush}" />
                                <TextBlock Text="{Binding UpRate, Mode=OneWay, Converter={StaticResource SpeedUnit}}"
                                           FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                           Foreground="{DynamicResource ChartUpBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>
