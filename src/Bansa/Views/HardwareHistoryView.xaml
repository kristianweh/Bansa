<UserControl x:Class="Bansa.Views.HardwareHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Hardware History" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,16"
                   Text="Record a session to log CPU/GPU temperatures and the apps that drove them, then export it." />

        <!-- Toolbar -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RecordBtn" Style="{StaticResource AccentButton}" Padding="14,7"
                            Click="OnRecordToggle">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="RecDot" Width="9" Height="9" Fill="White"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock x:Name="RecordBtnText" Text="Record session" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="ElapsedText" Text="" VerticalAlignment="Center" Margin="14,0,0,0"
                               FontFamily="{StaticResource RobotoMonoFamily}" Foreground="{DynamicResource SubtleTextBrush}" />
                    <TextBlock x:Name="SampleCountText" Text="" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="View" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                    <ComboBox x:Name="SessionPicker" Width="210" MinWidth="180"
                              SelectionChanged="OnSessionPicked"
                              ToolTip="Switch between the current/live recording and saved sessions" />
                    <Button x:Name="DeleteBtn" Content="Delete" Padding="12,6" Margin="8,0,0,0"
                            Click="OnDeleteSession" IsEnabled="False"
                            ToolTip="Delete the selected saved session" />
                    <Button x:Name="ExportBtn" Content="Export CSV…" Margin="8,0,0,0"
                            Padding="12,6" Click="OnExportCsv" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Session temperature timeline -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="18,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SESSION TEMPERATURE" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,8" />
                <Grid Grid.Row="1" MinHeight="180">
                    <Canvas x:Name="SessionChart" SizeChanged="OnChartSizeChanged" />
                    <TextBlock x:Name="EmptyNotice" Text="No session recorded yet — press Record."
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Border Width="14" Height="3" CornerRadius="2" VerticalAlignment="Center"
                            Background="{DynamicResource ChartCpuBrush}" Margin="0,0,6,0" />
                    <TextBlock Text="CPU" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,16,0" />
                    <Border Width="14" Height="3" CornerRadius="2" VerticalAlignment="Center"
                            Background="{DynamicResource ChartGpuBrush}" Margin="0,0,6,0" />
                    <TextBlock Text="GPU" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats + culprits -->
        <Grid Grid.Row="4" Margin="0,12,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="SESSION SUMMARY" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CPU" FontSize="11" Foreground="{DynamicResource ChartCpuBrush}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock x:Name="CpuStatsText" Text="—" FontFamily="{StaticResource RobotoMonoFamily}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="GPU" FontSize="11" Foreground="{DynamicResource ChartGpuBrush}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock x:Name="GpuStatsText" Text="—" FontFamily="{StaticResource RobotoMonoFamily}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="PeakText" Text="" Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="CULPRITS — HOTTEST APPS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,10" />
                    <StackPanel x:Name="CulpritsPanel" />
                    <TextBlock x:Name="CulpritsEmpty" Text="—" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
