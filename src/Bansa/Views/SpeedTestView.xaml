<UserControl x:Class="Bansa.Views.SpeedTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,16,0,0" MaxWidth="900" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Verify your limits" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,16">
                <Run Text="Two ways to verify that a limit is actually doing what you expect:" />
            </TextBlock>

            <!-- A: Self-test -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="18,16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="A — Self-test on Bansa.exe" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,0"
                                       Text="Downloads 25 MB from Cloudflare directly inside Bansa.exe. If you've set a download limit on Bansa.exe (back on the Processes tab), the achieved rate below should match it." />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="StartBtn"
                                Content="Start"
                                Padding="18,8" Style="{StaticResource AccentButton}"
                                VerticalAlignment="Center" Margin="16,0,0,0"
                                Click="OnStartSelfTest" />
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}">
                            <Run Text="Current: " />
                            <Run x:Name="CurrentMbps" Text="—" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" />
                            <Run Text=" Mbps" />
                        </TextBlock>
                        <Border Grid.Column="1" Background="{DynamicResource PanelAltBrush}" CornerRadius="3" Height="8"
                                VerticalAlignment="Center">
                            <Border x:Name="ProgressBar"
                                    Background="{DynamicResource AccentBrush}"
                                    HorizontalAlignment="Left"
                                    Width="0" Height="8" CornerRadius="3" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- B: External -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="18,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="B — Test under another app" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,10"
                               Text="To verify a limit on a specific app (e.g., Chrome): set the limit on that app first, then run a speed test inside it. Open the link below in the app you want to test, and watch its row on the Processes tab — its rate should plateau at the limit you set." />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open fast.com (default browser)" Padding="14,8" Click="OnOpenExternal" Margin="0,0,8,0" />
                        <Button Content="Copy URL to clipboard" Padding="14,8" Click="OnCopyUrl" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- C: How verification works -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="18,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="What to expect" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}">
                        <Run Text="•  Upload limit:" FontWeight="SemiBold" />
                        <Run Text=" smooth rate shaping via Windows QoS at the OS level. It caps a connection when it opens, so it may not bite until the app reconnects — the ↑ badge goes amber while a connection is still over the cap." />
                        <LineBreak />
                        <Run Text="•  Download limit:" FontWeight="SemiBold" />
                        <Run Text=" Bansa watches the actual rate via ETW and toggles a temporary inbound firewall block when the cap is exceeded. The average over a few seconds matches your cap; you may see brief stutters because there's no kernel driver doing smooth pacing." />
                        <LineBreak />
                        <Run Text="•  Block:" FontWeight="SemiBold" />
                        <Run Text=" instant — the app immediately loses all network access." />
                    </TextBlock>
                </StackPanel>
            </Border>
    </Grid>
</UserControl>
