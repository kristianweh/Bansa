<Window x:Class="Bansa.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bansa"
        SizeToContent="Height"
        Width="480" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <Border x:Name="AccentBar" Width="4" CornerRadius="2" Margin="0,2,12,2"
                    Background="{DynamicResource AccentGradientVerticalBrush}" />
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Message -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16,14">
            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
                           Foreground="{DynamicResource SubtleTextBrush}" />
            </ScrollViewer>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="CancelBtn" Content="Cancel" Click="OnCancel"
                    Padding="18,9" MinWidth="100" Margin="0,0,8,0" IsCancel="True" />
            <Button x:Name="ConfirmBtn" Content="Confirm" Click="OnConfirm"
                    Padding="18,9" MinWidth="120" IsDefault="True"
                    Style="{StaticResource AccentButton}" />
        </StackPanel>
    </Grid>
</Window>
