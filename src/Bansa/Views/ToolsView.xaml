<UserControl x:Class="Bansa.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Bansa.ViewModels">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,8,24,24">

            <!-- Header -->
            <TextBlock Text="Tools" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Portable utilities — downloaded once into your Bansa folder."
                       Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,20" />

            <!-- Card grid — WrapPanel rows, all cards identical dimensions -->
            <ItemsControl ItemsSource="{Binding Tools}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- ItemHeight forces every card slot to the same height so
                             buttons in the same row are always horizontally aligned -->
                        <WrapPanel Orientation="Horizontal" ItemWidth="222" ItemHeight="350" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PortableToolItem}">

                        <!-- Card — fills its 222×350 WrapPanel slot (12px right gap) -->
                        <Border Width="210" Margin="0,0,0,0" VerticalAlignment="Stretch"
                                CornerRadius="10"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid ClipToBounds="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="90" />   <!-- coloured tile  -->
                                    <RowDefinition Height="*"  />   <!-- body — flexible -->
                                    <RowDefinition Height="Auto" /> <!-- button — pinned -->
                                </Grid.RowDefinitions>

                                <!-- ── Coloured logo tile ── -->
                                <Border Grid.Row="0"
                                        Background="{Binding TileBrush}"
                                        CornerRadius="9,9,0,0">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="40"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Opacity="0.90" />
                                </Border>

                                <!-- ── Body (name + description + status/progress) ── -->
                                <StackPanel Grid.Row="1" Margin="13,11,13,8">

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="0,0,0,4" />

                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11.5"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="16"
                                               MaxHeight="56"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8" />

                                    <!-- ── Downloading state ── -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />

                                        <Border Background="{DynamicResource PanelAltBrush}"
                                                CornerRadius="3" Height="4">
                                            <Border Background="{Binding TileBrush}"
                                                    HorizontalAlignment="Left"
                                                    Height="4" CornerRadius="3">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                                        <Binding Path="Progress" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}"
                                                                 Path="ActualWidth" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Border>
                                    </StackPanel>

                                    <!-- ── Idle state ── -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <DockPanel>
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6"
                                                     VerticalAlignment="Top" Margin="0,3,5,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                <Setter Property="Fill" Value="#4CAF50" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsScript}" Value="True">
                                                                <Setter Property="Fill" Value="#FF9800" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding SubLabel}"
                                                       FontSize="10.5"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>

                                        <TextBlock Text="{Binding Error}"
                                                   Foreground="#EF5350"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   MaxHeight="40" TextTrimming="CharacterEllipsis"
                                                   Margin="0,4,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Error}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Fallback: open website when download keeps failing -->
                                        <Button Padding="0,6" HorizontalAlignment="Stretch"
                                                Margin="0,4,0,0"
                                                Command="{Binding OpenWebsiteCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowFallbackButton}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="Open website →" FontSize="11" FontWeight="Medium" />
                                        </Button>
                                    </StackPanel>

                                </StackPanel>

                                <!-- ── Button row — always pinned to the bottom of the card ── -->
                                <Grid Grid.Row="2" Margin="13,0,13,13">
                                    <!-- Action button (hidden while downloading) -->
                                    <Button Padding="0,8" HorizontalAlignment="Stretch"
                                            Command="{Binding ActionCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding ButtonLabel}" FontSize="12" FontWeight="Medium" />
                                    </Button>

                                    <!-- Cancel button (visible only while downloading) -->
                                    <Button Content="Cancel" Padding="0,8"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding CancelCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
