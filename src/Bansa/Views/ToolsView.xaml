<UserControl x:Class="Bansa.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Bansa.ViewModels">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,8,24,24">

            <!-- Header -->
            <TextBlock Text="Tools" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Portable utilities — launch from your Bansa folder."
                       Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,20" />

            <ItemsControl ItemsSource="{Binding Tools}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="222" ItemHeight="300" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ToolItem}">

                        <!-- Card -->
                        <Border Width="210" VerticalAlignment="Stretch"
                                CornerRadius="10"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="90" />   <!-- coloured tile  -->
                                    <RowDefinition Height="*"  />   <!-- body           -->
                                    <RowDefinition Height="Auto" /> <!-- buttons        -->
                                </Grid.RowDefinitions>

                                <!-- Coloured logo tile -->
                                <Border Grid.Row="0"
                                        Background="{Binding TileBrush}"
                                        CornerRadius="9,9,0,0">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="40" Foreground="White" Opacity="0.90"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Body -->
                                <StackPanel Grid.Row="1" Margin="13,11,13,8">

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="0,0,0,4" />

                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11.5"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               TextWrapping="Wrap" LineHeight="16"
                                               MaxHeight="48" TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8" />

                                    <!-- Install status dot + label -->
                                    <DockPanel>
                                        <Ellipse DockPanel.Dock="Left" Width="6" Height="6"
                                                 VerticalAlignment="Top" Margin="0,3,5,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                            <Setter Property="Fill" Value="#4CAF50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsScript}" Value="True">
                                                            <Setter Property="Fill" Value="#FF9800" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding SubLabel}"
                                                   FontSize="10.5"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </DockPanel>

                                    <!-- Status / error message -->
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="#EF5350" FontSize="11"
                                               TextWrapping="Wrap" MaxHeight="36"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,5,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </StackPanel>

                                <!-- Button row -->
                                <Grid Grid.Row="2" Margin="13,0,13,13">

                                    <!-- Portable tool: Website + Open side by side -->
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScript}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Padding="0,8"
                                                Command="{Binding OpenWebsiteCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                    <Setter Property="Opacity" Value="0.75" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="Website →" FontSize="11" FontWeight="Medium" />
                                        </Button>

                                        <Button Grid.Column="2" Padding="0,8"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding OpenCommand}">
                                            <TextBlock Text="Open" FontSize="11" FontWeight="Medium" />
                                        </Button>
                                    </Grid>

                                    <!-- Script tool: single Run button -->
                                    <Button Padding="0,8" HorizontalAlignment="Stretch"
                                            Command="{Binding OpenCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScript}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="Run" FontSize="12" FontWeight="Medium" />
                                    </Button>

                                </Grid>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
