<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Light palette — "Signal" design language
        ─────────────────────────────────────────────────────────────────────────
        Cool blue-grey base keeps visual kinship with the dark theme.  Cards
        lift naturally against the off-white background.  The accent shifts to a
        deeper teal (#007BA8) that reads confidently on light surfaces, while the
        upload amber is deepened slightly for contrast compliance.
    -->

    <!-- ── Surface hierarchy ─────────────────────────────────────────────── -->
    <Color x:Key="BgColor">#EDF0F7</Color>        <!-- cool off-white base              -->
    <Color x:Key="PanelColor">#FFFFFF</Color>      <!-- card / sidebar surface           -->
    <Color x:Key="PanelAltColor">#E4E8F2</Color>  <!-- inputs, secondary panels         -->
    <Color x:Key="HoverColor">#D8DCF0</Color>     <!-- hover state                      -->
    <Color x:Key="PressColor">#C8CEEA</Color>     <!-- pressed / active                 -->

    <!-- ── Accent: deep teal (readable on light) ─────────────────────────── -->
    <Color x:Key="AccentColor">#007BA8</Color>
    <Color x:Key="AccentAltColor">#2255CC</Color>
    <Color x:Key="AccentHoverColor">#0090C4</Color>

    <!-- ── Semantic colours ───────────────────────────────────────────────── -->
    <Color x:Key="DangerColor">#C0243A</Color>
    <Color x:Key="SuccessColor">#1A8A52</Color>
    <Color x:Key="WarningColor">#B86020</Color>

    <!-- ── Typography hierarchy ───────────────────────────────────────────── -->
    <Color x:Key="TextColor">#1A2030</Color>       <!-- near-black with navy tint        -->
    <Color x:Key="SubtleTextColor">#4A6880</Color>  <!-- secondary / labels               -->
    <Color x:Key="MutedTextColor">#9AAABB</Color>   <!-- placeholders / hints             -->

    <!-- ── Border: subtle definition ─────────────────────────────────────── -->
    <Color x:Key="BorderColor">#C8D0E4</Color>

    <!-- ── Chart defaults ────────────────────────────────────────────────── -->
    <Color x:Key="ChartDownColor">#007BA8</Color>
    <Color x:Key="ChartUpColor">#B86020</Color>

    <!-- ══ Brushes ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BgBrush"          Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="PanelBrush"       Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelAltBrush"    Color="{StaticResource PanelAltColor}" />
    <SolidColorBrush x:Key="HoverBrush"       Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush"     Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="TextBrush"        Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="SubtleTextBrush"  Color="{StaticResource SubtleTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush"   Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ChartDownBrush"   Color="{StaticResource ChartDownColor}" />
    <SolidColorBrush x:Key="ChartUpBrush"     Color="{StaticResource ChartUpColor}" />
    <SolidColorBrush x:Key="ChartCpuBrush"    Color="#007BA8" />
    <SolidColorBrush x:Key="ChartGpuBrush"    Color="#B86020" />
    <SolidColorBrush x:Key="ChartRamBrush"    Color="#1A8A52" />

    <!-- Gradient brushes (mirrors Dark.xaml structure — see there for notes) -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentColor}"    Offset="0" />
        <GradientStop Color="{StaticResource AccentAltColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientVerticalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AccentColor}"    Offset="0" />
        <GradientStop Color="{StaticResource AccentAltColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroDownRuleBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
        <GradientStop Color="#00000000"                    Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroUpRuleBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ChartUpColor}" Offset="0" />
        <GradientStop Color="#00000000"                     Offset="1" />
    </LinearGradientBrush>
    <!-- Active nav item: subtle teal-tinted surface -->
    <SolidColorBrush x:Key="AccentMutedBrush" Color="#E0F2FA" />

    <!-- Glass border — barely-visible shadow on card tops -->
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#18000000" />

    <!-- ── Selection / press surface ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="PressColorBrush"  Color="{StaticResource PressColor}" />
    <SolidColorBrush x:Key="WindowBrush"      Color="{StaticResource PanelColor}" />

    <!-- Badge tints -->
    <SolidColorBrush x:Key="BadgeBlockedBg" Color="#FCDEE2" />
    <SolidColorBrush x:Key="BadgeLimitBg"   Color="#D4F0E0" />
    <SolidColorBrush x:Key="BadgeGameBg"    Color="#D0E8F8" />
    <SolidColorBrush x:Key="BadgeLocalBg"   Color="#E4EAF8" />
    <SolidColorBrush x:Key="BadgeLocalFg"   Color="#4A6880" />

</ResourceDictionary>
