<Application x:Class="Bansa.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Bansa"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme dict loaded first; ThemeManager swaps Dark.xaml/Light.xaml at index 0 at startup.
                     Per-domain accent is layered on top in code by DomainManager (root-dict overrides). -->
                <ResourceDictionary Source="Themes/Dark.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:ProgressWidthConverter x:Key="ProgressWidthConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
