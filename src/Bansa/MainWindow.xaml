<Window x:Class="Bansa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Bansa.ViewModels"
        xmlns:views="clr-namespace:Bansa.Views"
        Title="Bansa"
        Height="800" Width="1280"
        MinHeight="540" MinWidth="960"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0,0,0,1"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel x:Name="MainVm" />
    </Window.DataContext>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />     <!-- custom title bar -->
            <RowDefinition Height="*" />      <!-- content (sidebar + view) -->
            <RowDefinition Height="Auto" />   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ═════════════════ Custom title bar ═════════════════ -->
        <Grid Grid.Row="0" Background="{DynamicResource BgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                <Image x:Name="BrandLogo" Height="28" Width="28"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="BANSA" Margin="10,0,0,0"
                           FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="Bold" FontSize="13"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="  bandwidth monitor"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           FontSize="12" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Drag area — explicit DragMove so moving always works -->
            <Border Grid.Column="1" Background="Transparent"
                    MouseLeftButtonDown="OnTitleBarDrag" />

            <!-- Caption buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource CaptionButton}"
                        Content="&#xE921;"   ToolTip="Minimize"
                        Click="OnMinimize" />
                <Button Style="{StaticResource CaptionButton}"
                        x:Name="MaxBtn"
                        Content="&#xE922;"   ToolTip="Maximize"
                        Click="OnMaxRestore" />
                <Button Style="{StaticResource CloseButton}"
                        Content="&#xE8BB;"   ToolTip="Close"
                        Click="OnClose"
                        MouseEnter="OnCloseEnter" MouseLeave="OnCloseLeave"
                        x:Name="CloseBtn" />
            </StackPanel>
        </Grid>

        <!-- ═════════════════ Body ═════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,1,0"
                    CornerRadius="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="10,14,10,0">
                        <TextBlock Style="{StaticResource NavSectionLabel}" Text="NAVIGATION" />
                        <!-- Dashboard -->
                        <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" x:Name="NavDashboard"
                                     IsChecked="True" Click="OnNavClick" Tag="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,12,0" FontSize="16" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <!-- Network (processes) -->
                        <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" x:Name="NavProcesses"
                                     Click="OnNavClick" Tag="1" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xF785;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,12,0" FontSize="16" />
                                <TextBlock Text="Network" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <!-- Hardware -->
                        <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" x:Name="NavHardware"
                                     Click="OnNavClick" Tag="2" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE950;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,12,0" FontSize="16" />
                                <TextBlock Text="Hardware" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <!-- Tools -->
                        <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" x:Name="NavTools"
                                     Click="OnNavClick" Tag="3" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE90F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,12,0" FontSize="16" />
                                <TextBlock Text="Tools" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <!-- History -->
                        <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" x:Name="NavHistory"
                                     Click="OnNavClick" Tag="4" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,12,0" FontSize="16" />
                                <TextBlock Text="History" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <!-- Settings -->
                        <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" x:Name="NavSettings"
                                     Click="OnNavClick" Tag="5" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,12,0" FontSize="16" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Live totals + Gaming Mode at the bottom of the sidebar -->
                    <StackPanel Grid.Row="1" Margin="10,0,10,12">
                        <!-- Hairline separator above bottom widget cluster -->
                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,0" Opacity="0.6" />
                        <TextBlock Style="{StaticResource NavSectionLabel}" Text="STATUS" Margin="14,8,14,6" />
                        <!-- No ClipToBounds — Roboto Mono's ascenders clip against rounded corners with it on -->
                        <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="8" Margin="0,0,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="12,10">
                                    <TextBlock Text="DOWN" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ChartDownBrush}" Margin="0,0,0,1" />
                                    <!-- Number large, unit smaller — avoids clipping from single oversized string -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TotalDownText, Converter={StaticResource SpeedValue}}"
                                                   FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="SemiBold"
                                                   FontSize="15" Foreground="{DynamicResource ChartDownBrush}" />
                                        <TextBlock Text="{Binding TotalDownText, Converter={StaticResource SpeedUnit}}"
                                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                                   FontSize="10" Foreground="{DynamicResource ChartDownBrush}"
                                                   VerticalAlignment="Bottom" Margin="3,0,0,2" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding TodayDownText, StringFormat='Today: {0}'}"
                                               FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="0,1,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource BorderBrush}" />
                                <StackPanel Grid.Column="2" Margin="12,10">
                                    <TextBlock Text="UP" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ChartUpBrush}" Margin="0,0,0,1" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TotalUpText, Converter={StaticResource SpeedValue}}"
                                                   FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="SemiBold"
                                                   FontSize="15" Foreground="{DynamicResource ChartUpBrush}" />
                                        <TextBlock Text="{Binding TotalUpText, Converter={StaticResource SpeedUnit}}"
                                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                                   FontSize="10" Foreground="{DynamicResource ChartUpBrush}"
                                                   VerticalAlignment="Bottom" Margin="3,0,0,2" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding TodayUpText, StringFormat='Today: {0}'}"
                                               FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="0,1,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                                Cursor="Hand" MouseLeftButtonDown="OnSidebarPingClick"
                                ToolTip="Click to manage ping targets">
                            <StackPanel>
                                <TextBlock Text="{Binding PingDisplayLabel}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           ToolTip="{Binding PingDisplayLabel}" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SidebarPingText"
                                               Text="{Binding PingText, Converter={StaticResource SpeedValue}}"
                                               FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock x:Name="SidebarPingUnit"
                                               Text="{Binding PingText, Converter={StaticResource SpeedUnit}}"
                                               FontFamily="{StaticResource RobotoMonoFamily}"
                                               FontSize="10" VerticalAlignment="Bottom" Margin="3,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Gaming Mode toggle — styled as a card, not a raw button -->
                        <Border x:Name="GamingModeCard" CornerRadius="8" Padding="12,9"
                                Cursor="Hand" MouseLeftButtonDown="OnGamingModeBtnClick"
                                ToolTip="Toggle Gaming Mode — applies per-app limits defined in Settings → Gaming Mode">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <!-- ON / OFF pill -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xE7FC;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="9" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="GAMING MODE" />
                                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                                        <Setter Property="Foreground" Value="#BBE0F8" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Margin="0,1,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="Off" />
                                                <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                                        <Setter Property="Text"       Value="Active" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content area — x:Name for panel-transition animation -->
            <Grid x:Name="ContentArea" Grid.Column="1" Margin="20,16,20,10" Background="Transparent">

                <!-- ══════════ DASHBOARD ══════════ -->
                <Grid x:Name="DashboardPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />   <!-- header -->
                        <RowDefinition Height="Auto" />   <!-- hero stats row -->
                        <RowDefinition Height="Auto" />   <!-- hardware bar -->
                        <RowDefinition Height="*" />      <!-- active processes -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" CornerRadius="2"
                                    Margin="0,4,12,4"
                                    Background="{DynamicResource AccentGradientVerticalBrush}" />
                            <StackPanel>
                                <TextBlock Text="Dashboard" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="Live overview"
                                           FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Padding="12,7" Click="OnFloatGraphToggle">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Float Graph" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Hero: Download + Upload + Ping + Gaming Mode -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="150" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                        </Grid.ColumnDefinitions>

                        <!-- Download card — cyan ambient tint, hover-lift animation -->
                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="18,18"
                                Background="{DynamicResource HeroDownCardBrush}"
                                Cursor="Hand" MouseLeftButtonDown="OnDashBandwidthClick"
                                ToolTip="Click to open Network tab"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-4" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="0" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <StackPanel>
                                <TextBlock Text="DOWNLOAD" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ChartDownBrush}" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TotalDownText, Converter={StaticResource SpeedValue}}"
                                               FontSize="28" FontWeight="Bold"
                                               FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartDownBrush}" />
                                    <TextBlock Text="{Binding TotalDownText, Converter={StaticResource SpeedUnit}}"
                                               FontSize="13" FontWeight="Medium"
                                               FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartDownBrush}"
                                               VerticalAlignment="Bottom" Margin="5,0,0,5" />
                                </StackPanel>
                                <Border Height="2" CornerRadius="1" Margin="0,10,0,8" HorizontalAlignment="Left" Width="32"
                                        Background="{DynamicResource HeroDownRuleBrush}" />
                                <TextBlock Text="{Binding TodayDownText, StringFormat='Today: {0}'}" FontSize="11"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Upload card — amber ambient tint, hover-lift animation -->
                        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18,18"
                                Background="{DynamicResource HeroUpCardBrush}"
                                Cursor="Hand" MouseLeftButtonDown="OnDashBandwidthClick"
                                ToolTip="Click to open Network tab"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-4" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="0" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <StackPanel>
                                <TextBlock Text="UPLOAD" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ChartUpBrush}" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TotalUpText, Converter={StaticResource SpeedValue}}"
                                               FontSize="28" FontWeight="Bold"
                                               FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartUpBrush}" />
                                    <TextBlock Text="{Binding TotalUpText, Converter={StaticResource SpeedUnit}}"
                                               FontSize="13" FontWeight="Medium"
                                               FontFamily="{StaticResource RobotoMonoFamily}"
                                               Foreground="{DynamicResource ChartUpBrush}"
                                               VerticalAlignment="Bottom" Margin="5,0,0,5" />
                                </StackPanel>
                                <Border Height="2" CornerRadius="1" Margin="0,10,0,8" HorizontalAlignment="Left" Width="32"
                                        Background="{DynamicResource HeroUpRuleBrush}" />
                                <TextBlock Text="{Binding TodayUpText, StringFormat='Today: {0}'}" FontSize="11"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Ping card — hover-lift animation -->
                        <Border Grid.Column="4" Style="{StaticResource Card}" Padding="18,18"
                                Cursor="Hand" MouseLeftButtonDown="OnDashPingClick"
                                ToolTip="Click to manage ping targets"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-4" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="0" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <StackPanel>
                                <TextBlock Text="PING" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="DashPingText"
                                               Text="{Binding PingText, Converter={StaticResource SpeedValue}}"
                                               FontSize="28" FontWeight="Bold" FontFamily="{StaticResource RobotoMonoFamily}" />
                                    <TextBlock x:Name="DashPingUnit"
                                               Text="{Binding PingText, Converter={StaticResource SpeedUnit}}"
                                               FontSize="13" FontWeight="Medium" FontFamily="{StaticResource RobotoMonoFamily}"
                                               VerticalAlignment="Bottom" Margin="5,0,0,5" />
                                </StackPanel>
                                <Canvas x:Name="DashPingSparkCanvas" Height="20" Margin="0,6,0,0"
                                        ClipToBounds="True">
                                    <Path x:Name="DashPingSparkPath"
                                          Stroke="{DynamicResource MutedTextBrush}"
                                          StrokeThickness="1.2" StrokeLineJoin="Round" />
                                </Canvas>
                            </StackPanel>
                        </Border>

                        <!-- Gaming Mode card -->
                        <Border Grid.Column="6" Padding="18,18">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="GAMING MODE" />
                                            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                                    <Setter Property="Foreground" Value="#BBE0F8" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="28" FontWeight="Bold" FontFamily="{StaticResource RobotoMonoFamily}"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Off" />
                                            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                                    <Setter Property="Text" Value="Active" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Margin="0,8,0,0" Padding="10,5" HorizontalAlignment="Left"
                                        Command="{Binding ToggleGamingModeCommand}"
                                        Click="OnGamingModeBtnClick">
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Enable" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGamingModeActive}" Value="True">
                                                        <Setter Property="Text" Value="Disable" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- System Health: 3 separate chip cards (CPU / GPU / RAM) -->
                    <Grid Grid.Row="2" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- CPU chip -->
                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20,14"
                                Cursor="Hand" MouseLeftButtonDown="OnDashHardwareClick"
                                ToolTip="Click to open Hardware tab"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-4" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="0" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE950;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="13" Foreground="{DynamicResource ChartCpuBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,7,0" />
                                        <TextBlock x:Name="DashCpuName" Text="CPU" FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="120" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <TextBlock x:Name="DashCpuPct" Text="—"
                                                   FontSize="22" FontWeight="Bold" FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Padding="0,3"
                                                   Foreground="{DynamicResource ChartCpuBrush}" />
                                        <TextBlock x:Name="DashCpuTempSign" Text="°C" FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Foreground="{DynamicResource ChartCpuBrush}"
                                                   VerticalAlignment="Bottom" Margin="2,0,0,6" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar x:Name="DashCpuBar" Grid.Row="1" Style="{StaticResource CardProgress}"
                                             Foreground="{DynamicResource ChartCpuBrush}" Margin="0,0,0,8" />
                                <Grid Grid.Row="2">
                                    <TextBlock x:Name="DashCpuTemp" Text="" FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <TextBlock x:Name="DashCpuFreq" Text="" FontSize="11"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- GPU chip -->
                        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20,14"
                                Cursor="Hand" MouseLeftButtonDown="OnDashHardwareClick"
                                ToolTip="Click to open Hardware tab"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-4" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="0" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="13" Foreground="{DynamicResource ChartGpuBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,7,0" />
                                        <TextBlock x:Name="DashGpuName" Text="GPU" FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="120" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <TextBlock x:Name="DashGpuPct" Text="—"
                                                   FontSize="22" FontWeight="Bold" FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Foreground="{DynamicResource ChartGpuBrush}" />
                                        <TextBlock x:Name="DashGpuTempSign" Text="°C" FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Foreground="{DynamicResource ChartGpuBrush}"
                                                   VerticalAlignment="Bottom" Margin="2,0,0,4" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar x:Name="DashGpuBar" Grid.Row="1" Style="{StaticResource CardProgress}"
                                             Foreground="{DynamicResource ChartGpuBrush}" Margin="0,0,0,8" />
                                <Grid Grid.Row="2">
                                    <TextBlock x:Name="DashGpuTemp" Text="" FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <TextBlock x:Name="DashGpuClock" Text="" FontSize="11"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- RAM chip -->
                        <Border Grid.Column="4" Style="{StaticResource Card}" Padding="20,14"
                                Cursor="Hand" MouseLeftButtonDown="OnDashHardwareClick"
                                ToolTip="Click to open Hardware tab">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE179;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="13" Foreground="{DynamicResource ChartRamBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,7,0" />
                                        <TextBlock Text="RAM" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <TextBlock x:Name="DashRamPct" Text="—"
                                                   FontSize="22" FontWeight="Bold" FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Foreground="{DynamicResource ChartRamBrush}" />
                                        <TextBlock Text="%" FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Foreground="{DynamicResource ChartRamBrush}"
                                                   VerticalAlignment="Bottom" Margin="2,0,0,4" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar x:Name="DashRamBar" Grid.Row="1" Style="{StaticResource CardProgress}"
                                             Foreground="{DynamicResource ChartRamBrush}" Margin="0,0,0,8" />
                                <Grid Grid.Row="2">
                                    <TextBlock x:Name="DashRamUsed" Text="" FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <TextBlock x:Name="DashRamTotal" Text="" FontSize="11"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Active processes card -->
                    <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Card header -->
                            <Grid Grid.Row="0" Margin="20,14,20,14">
                                <TextBlock Text="ACTIVE PROCESSES" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                                <Button Content="View all →" HorizontalAlignment="Right"
                                        Padding="8,4" FontSize="11" Click="OnDashViewAllClick"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource AccentBrush}" />
                            </Grid>
                            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                                    Background="{DynamicResource BorderBrush}" />

                            <!-- Mini process grid -->
                            <DataGrid Grid.Row="1"
                                      x:Name="DashAppGrid"
                                      ItemsSource="{Binding AppsView}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      IsReadOnly="True" SelectionMode="Single"
                                      RowHeight="38"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      MouseDoubleClick="OnAppDoubleClick"
                                      PreviewMouseDoubleClick="OnColumnHeaderDoubleClick"
                                      PreviewMouseRightButtonDown="OnDashAppGridRowRightClick">
                                <DataGrid.ContextMenu>
                                    <ContextMenu Opened="OnAppContextMenuOpened">
                                        <MenuItem Click="OnPinClick">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBlock Text="Pin to top" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Header="Unpin" Click="OnUnpinClick" />
                                        <Separator />
                                        <MenuItem Header="Set limits…" Click="OnSetLimitClick" />
                                        <MenuItem Header="Quick profile ▶" Tag="QuickProfile">
                                            <!-- Placeholder keeps the submenu popup template alive so items
                                                 added at runtime during Opened are rendered correctly -->
                                            <MenuItem Visibility="Collapsed" />
                                        </MenuItem>
                                        <MenuItem Header="Clear limits" Click="OnClearLimitsClick" />
                                        <Separator />
                                        <MenuItem Header="Block this app" Click="OnBlockClick" />
                                        <MenuItem Header="Unblock this app" Click="OnUnblockClick" />
                                        <Separator />
                                        <MenuItem Header="Show individual processes" Click="OnShowPidsClick" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                        <Setter Property="ToolTip" Value="{Binding HourlyTooltip}" />
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="App" Width="160" MinWidth="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,10,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="↓ Down" SortMemberPath="BytesInPerSec" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DownRate, Converter={StaticResource SpeedValue}}"
                                                               FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource ChartDownBrush}" />
                                                    <TextBlock Text="{Binding DownRate, Converter={StaticResource SpeedUnit}}"
                                                               FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                                               Foreground="{DynamicResource ChartDownBrush}"
                                                               VerticalAlignment="Bottom" Margin="2,0,0,2" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="↑ Up" SortMemberPath="BytesOutPerSec" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding UpRate, Converter={StaticResource SpeedValue}}"
                                                               FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource ChartUpBrush}" />
                                                    <TextBlock Text="{Binding UpRate, Converter={StaticResource SpeedUnit}}"
                                                               FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                                               Foreground="{DynamicResource ChartUpBrush}"
                                                               VerticalAlignment="Bottom" Margin="2,0,0,2" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="30 s" Width="80" CanUserSort="False" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Viewbox Width="64" Height="16" Stretch="Fill" HorizontalAlignment="Left">
                                                    <Path Stroke="{DynamicResource ChartDownBrush}" StrokeThickness="1.5"
                                                          Data="{Binding DownSparkGeometry}" Width="80" Height="18" />
                                                </Viewbox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Status badges — limits and priority, mirroring the Network panel -->
                                    <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="72" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Background="{DynamicResource BadgeBlockedBg}" CornerRadius="3" Padding="5,1" Margin="0,0,3,0"
                                                            Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="Blocked" Foreground="{DynamicResource DangerBrush}" FontSize="10" FontWeight="SemiBold" />
                                                    </Border>
                                                    <!-- Upload limit badge (smooth QoS cap): green = holding, amber = exceeding the cap -->
                                                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,3,0"
                                                            ToolTip="Upload limit (smooth QoS cap). Green = holding. Amber = the app is exceeding it — QoS caps new connections, so it takes effect when the app reconnects (or restart the app).">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Background" Value="{DynamicResource BadgeLimitBg}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UploadLimitKbps}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsUploadCapExceeded}" Value="True">
                                                                        <Setter Property="Background" Value="#33F59E0B" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsUploadCapExceeded}" Value="True">
                                                                            <Setter Property="Foreground" Value="#F59E0B" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="↑ " /><Run Text="{Binding UploadLimitText, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </Border>
                                                    <!-- Download limit badge -->
                                                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,3,0"
                                                            ToolTip="Download limit set. Turns amber while the firewall rule is actively enforcing.">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Background" Value="{DynamicResource BadgeLimitBg}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DownloadLimitKbps}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsThrottlingDown}" Value="True">
                                                                        <Setter Property="Background" Value="#33F59E0B" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsThrottlingDown}" Value="True">
                                                                            <Setter Property="Foreground" Value="#F59E0B" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="↓ " /><Run Text="{Binding DownloadLimitText, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══════════ NETWORK (processes) ══════════ -->
                <!-- PROCESSES -->
                <Grid x:Name="ProcPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="130" MinHeight="60" />   <!-- live graph (user-resizable) -->
                        <RowDefinition Height="6" />                     <!-- drag handle -->
                        <RowDefinition Height="*" MinHeight="80" />     <!-- app grid -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" CornerRadius="2"
                                    Margin="0,4,12,4"
                                    Background="{DynamicResource AccentGradientVerticalBrush}" />
                            <StackPanel>
                                <TextBlock Text="Network" FontSize="22" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="TODAY" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="↓" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ChartDownBrush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="{Binding TodayDownText}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ChartDownBrush}"
                                               VerticalAlignment="Center" Margin="0,0,14,0" />
                                    <TextBlock Text="↑" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ChartUpBrush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="{Binding TodayUpText}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ChartUpBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Padding="10,5" Click="OnFloatGraphToggle"
                                ToolTip="Show / hide floating bandwidth graph on any monitor">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Float Graph" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Filter bar: search left, controls right -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"    MaxWidth="340" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Search box with inline clear button -->
                        <Grid Grid.Column="0">
                            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,7,34,7" ToolTip="Filter by app name" />
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="28" Height="28" Margin="0,0,3,0"
                                    Click="OnClearFilter" ToolTip="Clear filter"
                                    Padding="0" Background="Transparent" BorderThickness="0">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="12" Foreground="{DynamicResource MutedTextBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                        </Grid>

                        <!-- Right-side controls: presets → hide-local → threshold slider -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Margin="14,0,0,0" VerticalAlignment="Center">
                            <Button Content="All"      Padding="8,5" Margin="0,0,3,0"
                                    Click="OnPresetAll" ToolTip="Show all apps" />
                            <Button Content="≥1 KB/s"  Padding="8,5" Margin="0,0,3,0"
                                    Click="OnPreset1"   ToolTip="Hide apps below 1 KB/s" />
                            <Button Content="≥10 KB/s" Padding="8,5" Margin="0,0,3,0"
                                    Click="OnPreset10"  ToolTip="Hide apps below 10 KB/s" />
                            <Button Content="≥50 KB/s" Padding="8,5" Margin="0,0,14,0"
                                    Click="OnPreset50"  ToolTip="Hide apps below 50 KB/s" />

                            <!-- Divider -->
                            <Border Width="1" Height="18" Background="{DynamicResource BorderBrush}"
                                    VerticalAlignment="Center" Margin="0,0,14,0" Opacity="0.6" />

                            <CheckBox Content="Hide local" Margin="0,0,14,0"
                                      IsChecked="{Binding HideLocalOnlyApps}"
                                      VerticalAlignment="Center"
                                      ToolTip="Hide apps whose connections are all loopback/LAN" />
                            <TextBlock Text="{Binding ThresholdLabel}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" Margin="0,0,8,0" />
                            <Slider Width="140" Minimum="0" Maximum="200" Value="{Binding HideBelowKBps}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                    ToolTip="Hide apps below this KB/s threshold" />
                        </StackPanel>
                    </Grid>

                    <!-- Live bandwidth graph -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,0" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Toolbar: legend left, controls right — completely outside the canvas -->
                                <RowDefinition Height="30" />
                                <!-- Canvas area: clean, no overlapping controls -->
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Chart toolbar row -->
                            <Grid Grid.Row="0" Margin="10,0,8,0">
                                <!-- Left: legend dots -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            IsHitTestVisible="False">
                                    <Ellipse Width="7" Height="7" Fill="{DynamicResource ChartDownBrush}"
                                             Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Download" FontSize="10"
                                               Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    <Ellipse Width="7" Height="7" Fill="{DynamicResource ChartUpBrush}"
                                             Margin="10,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Upload" FontSize="10"
                                               Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Right: peak label, window label, dual-scale toggle -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="MainChartPeakLabel"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,0,8,0" IsHitTestVisible="False" />
                                    <TextBlock x:Name="ChartWindowLabel" Text="30 s" FontSize="10"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,0,8,0" IsHitTestVisible="False" />
                                    <!-- SmallToggle: rounded box, not pill -->
                                    <ToggleButton x:Name="DualScaleBtn" Style="{StaticResource SmallToggle}"
                                                  Content="Dual scale"
                                                  ToolTip="On: download and upload use independent Y-axis scales"
                                                  Click="OnDualScaleClick" />
                                </StackPanel>
                            </Grid>

                            <!-- Canvas area — no controls overlap this row -->
                            <Border Grid.Row="1" CornerRadius="0,0,4,4"
                                    Background="{DynamicResource PanelAltBrush}" />
                            <Canvas x:Name="MainChartCanvas" Grid.Row="1" ClipToBounds="True" />
                            <!-- Crosshair overlay -->
                            <Canvas x:Name="ChartOverlay" Grid.Row="1" ClipToBounds="True"
                                    Background="Transparent"
                                    MouseMove="OnChartMouseMove"
                                    MouseLeave="OnChartMouseLeave"
                                    MouseLeftButtonDown="OnChartMouseDown"
                                    MouseLeftButtonUp="OnChartMouseUp" />
                            <!-- Pause banner -->
                            <Border x:Name="PauseBanner" Grid.Row="1"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    Background="#BB000000" Padding="0,5"
                                    Visibility="Collapsed" IsHitTestVisible="False">
                                <TextBlock Text="⏸  Paused — click to resume"
                                           HorizontalAlignment="Center"
                                           FontSize="11" FontWeight="SemiBold" Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Drag handle between chart and app grid -->
                    <GridSplitter x:Name="ChartSplitter"
                                  Grid.Row="3"
                                  Height="6" HorizontalAlignment="Stretch"
                                  Background="Transparent"
                                  Cursor="SizeNS"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  DragCompleted="OnChartSplitterDragCompleted">
                        <GridSplitter.Template>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="Transparent" HorizontalAlignment="Stretch">
                                    <Rectangle Height="2" Width="28" Fill="{DynamicResource BorderBrush}"
                                               RadiusX="1" RadiusY="1" Opacity="0.7"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </GridSplitter.Template>
                    </GridSplitter>

                    <Border Grid.Row="4" Style="{StaticResource Card}">
                        <DataGrid x:Name="AppGrid"
                                  ItemsSource="{Binding AppsView}"
                                  SelectedItem="{Binding SelectedApp}"
                                  AutoGenerateColumns="False"
                                  PreviewMouseRightButtonDown="OnAppGridHeaderRightClick"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True" SelectionMode="Single"
                                  RowHeight="40"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  MouseDoubleClick="OnAppDoubleClick"
                                  Sorting="OnAppGridSorting"
                                  PreviewMouseDoubleClick="OnColumnHeaderDoubleClick">
                            <DataGrid.RowStyle>
                                <!-- Inherits hover/select from global DataGridRow style; adds tooltip. -->
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="ToolTip" Value="{Binding HourlyTooltip}" />
                                    <Setter Property="ToolTipService.InitialShowDelay" Value="700" />
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="App" Width="200" SortMemberPath="Name" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Icon}" Width="18" Height="18" Margin="0,0,10,0"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Procs"   Binding="{Binding ProcessCount}"   SortMemberPath="ProcessCount" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource RobotoMonoFamily}" />
                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="↓ Down" SortMemberPath="BytesInPerSec" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DownRate, Converter={StaticResource SpeedValue}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ChartDownBrush}" />
                                                <TextBlock Text="{Binding DownRate, Converter={StaticResource SpeedUnit}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                                           Foreground="{DynamicResource ChartDownBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,2" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="↑ Up" SortMemberPath="BytesOutPerSec" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UpRate, Converter={StaticResource SpeedValue}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ChartUpBrush}" />
                                                <TextBlock Text="{Binding UpRate, Converter={StaticResource SpeedUnit}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                                           Foreground="{DynamicResource ChartUpBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,2" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Per-app 30-second download sparkline -->
                                <DataGridTemplateColumn Header="↓ 30 s" Width="88"
                                                        CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox Width="72" Height="20" Stretch="Fill"
                                                     HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Path Stroke="{DynamicResource ChartDownBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round"
                                                      Data="{Binding DownSparkGeometry}"
                                                      Width="80" Height="18" />
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Per-app 30-second upload sparkline -->
                                <DataGridTemplateColumn Header="↑ 30 s" Width="88"
                                                        CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox Width="72" Height="20" Stretch="Fill"
                                                     HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Path Stroke="{DynamicResource ChartUpBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round"
                                                      Data="{Binding UpSparkGeometry}"
                                                      Width="80" Height="18" />
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Total ↓" SortMemberPath="TotalBytesIn" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TotalDown, Converter={StaticResource SpeedValue}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                                <TextBlock Text="{Binding TotalDown, Converter={StaticResource SpeedUnit}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,2" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Total ↑" SortMemberPath="TotalBytesOut" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TotalUp, Converter={StaticResource SpeedValue}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                                <TextBlock Text="{Binding TotalUp, Converter={StaticResource SpeedUnit}}"
                                                           FontFamily="{StaticResource RobotoMonoFamily}" FontSize="9"
                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,2" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Status" Width="240" SortMemberPath="IsBlocked">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="{DynamicResource BadgeBlockedBg}" CornerRadius="3" Padding="6,2" Margin="0,0,4,0"
                                                        Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Blocked" Foreground="{DynamicResource DangerBrush}" FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                                <!-- Upload limit badge (smooth QoS cap): green = holding, amber = exceeding the cap -->
                                                <Border CornerRadius="3" Padding="6,2" Margin="0,0,4,0"
                                                        ToolTip="Upload limit (smooth QoS cap). Green = holding. Amber = the app is exceeding it — QoS caps new connections, so it takes effect when the app reconnects (or restart the app).">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Setter Property="Background" Value="{DynamicResource BadgeLimitBg}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UploadLimitKbps}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsUploadCapExceeded}" Value="True">
                                                                    <Setter Property="Background" Value="#33F59E0B" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUploadCapExceeded}" Value="True">
                                                                        <Setter Property="Foreground" Value="#F59E0B" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="↑ " /><Run Text="{Binding UploadLimitText, Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                                <!-- Download limit badge: green at rest, amber when block rule is firing -->
                                                <Border CornerRadius="3" Padding="6,2" Margin="0,0,4,0"
                                                        ToolTip="Download limit set. Badge turns amber while the block rule is actively enforcing the cap.">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Setter Property="Background" Value="{DynamicResource BadgeLimitBg}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DownloadLimitKbps}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsThrottlingDown}" Value="True">
                                                                    <Setter Property="Background" Value="#33F59E0B" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsThrottlingDown}" Value="True">
                                                                        <Setter Property="Foreground" Value="#F59E0B" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="↓ " /><Run Text="{Binding DownloadLimitText, Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                                <!-- High connection count warning -->
                                                <Border CornerRadius="3" Padding="6,2"
                                                        Background="#33F59E0B"
                                                        Visibility="{Binding HighConnectionWarning, Converter={StaticResource BoolToVis}}"
                                                        ToolTip="This app has an unusually high number of connections (P2P, web crawler, or unusual activity).">
                                                    <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#F59E0B">
                                                        <Run Text="&#x26A0; " /><Run Text="{Binding ConnectionCount, Mode=OneWay}" /><Run Text=" conns" />
                                                    </TextBlock>
                                                </Border>
                                                <!-- Local / loopback-only badge -->
                                                <Border CornerRadius="3" Padding="6,2"
                                                        Background="{DynamicResource BadgeLocalBg}"
                                                        Visibility="{Binding IsLocalOnly, Converter={StaticResource BoolToVis}}"
                                                        ToolTip="All connections are loopback or LAN — no real internet traffic. This is IPC or local service communication (e.g. StreamDeck plugins, Razer Synapse). It never leaves your machine.">
                                                    <TextBlock Text="Local" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BadgeLocalFg}" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.ContextMenu>
                                <ContextMenu Opened="OnAppContextMenuOpened">
                                    <MenuItem Click="OnPinClick">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="Pin to top" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Header="Unpin" Click="OnUnpinClick" />
                                    <Separator />
                                    <MenuItem Header="Set limits…" Click="OnSetLimitClick" />
                                    <MenuItem Header="Quick profile ▶" Tag="QuickProfile">
                                        <MenuItem Visibility="Collapsed" />
                                    </MenuItem>
                                    <MenuItem Header="Clear limits" Click="OnClearLimitsClick" />
                                    <Separator />
                                    <MenuItem Header="Block this app" Click="OnBlockClick" />
                                    <MenuItem Header="Unblock this app" Click="OnUnblockClick" />
                                    <Separator />
                                    <MenuItem Header="Show individual processes" Click="OnShowPidsClick" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- HISTORY -->
                <views:HistoryView x:Name="HistoryPanel" Visibility="Collapsed" />

                <!-- TOOLS -->
                <views:ToolsView x:Name="ToolsPanel" Visibility="Collapsed" />

                <!-- SETTINGS -->
                <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="860" HorizontalAlignment="Left" Margin="0,8,0,0">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="4" CornerRadius="2" Margin="0,4,12,4"
                                    Background="{DynamicResource AccentGradientVerticalBrush}" />
                            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" />
                        </StackPanel>

                        <!-- ── Settings tab strip ── -->
                        <WrapPanel Margin="0,0,0,16">
                            <RadioButton x:Name="SettingsTabBtnGeneral"
                                         Style="{StaticResource SettingsTab}" GroupName="SettingsTabs"
                                         Tag="general" Content="General" IsChecked="True"
                                         Click="OnSettingsTabClick" />
                            <RadioButton x:Name="SettingsTabBtnNetwork"
                                         Style="{StaticResource SettingsTab}" GroupName="SettingsTabs"
                                         Tag="network" Content="Network"
                                         Click="OnSettingsTabClick" />
                            <RadioButton x:Name="SettingsTabBtnGamingMode"
                                         Style="{StaticResource SettingsTab}" GroupName="SettingsTabs"
                                         Tag="gamingmode" Content="Gaming Mode"
                                         Click="OnSettingsTabClick" />
                            <RadioButton x:Name="SettingsTabBtnAppearance"
                                         Style="{StaticResource SettingsTab}" GroupName="SettingsTabs"
                                         Tag="appearance" Content="Appearance"
                                         Click="OnSettingsTabClick" />
                        </WrapPanel>

                        <!-- ══ GENERAL tab: Units · Shortcut · Behavior · System ══ -->
                        <StackPanel x:Name="SettingsTabGeneral">

                            <!-- Units -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Units" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="UnitBytesRadio" GroupName="UnitChoice"
                                                     Content="Bytes (B / KB / MB / GB)"
                                                     Click="OnUnitBytesClick" Margin="0,0,20,0" />
                                        <RadioButton x:Name="UnitBitsRadio" GroupName="UnitChoice"
                                                     Content="Bits (b / Kb / Mb / Gb)"
                                                     Click="OnUnitBitsClick" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Global keyboard shortcut -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Global keyboard shortcut" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,10"
                                               Text="Global hotkey to show/hide Bansa from any app. Ctrl+Shift modifier is fixed; click Change to rebind the key. Click Clear to disable it entirely." />
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Show/hide:" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <Border Background="{DynamicResource PanelAltBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,12,0">
                                            <TextBlock x:Name="HotkeyLabel" Text="Ctrl+Shift+F"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                                        </Border>
                                        <Button x:Name="ChangeHotkeyBtn" Content="Change…" Padding="10,5" Click="OnChangeHotkeyClick" />
                                        <Button x:Name="ClearHotkeyBtn" Content="Clear" Padding="10,5" Margin="8,0,0,0"
                                                Click="OnClearHotkeyClick" ToolTip="Remove the global hotkey binding" />
                                    </StackPanel>
                                    <TextBlock x:Name="HotkeyCapturing" Text="▶  Press any key to set the binding  (Esc to cancel)"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="11"
                                               Margin="0,8,0,0" Visibility="Collapsed" />
                                </StackPanel>
                            </Border>

                            <!-- Behavior (startup + window) — all three toggles in one card -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Behavior" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />

                                    <!-- Launch on startup -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Launch on Windows startup" FontWeight="SemiBold" />
                                            <TextBlock x:Name="AutoStartStatusLabel"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="11" Margin="0,2,0,0" Text="Checking…" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Style="{StaticResource ThemeToggle}"
                                                      x:Name="AutoStartToggle"
                                                      Click="OnAutoStartToggleClick" />
                                    </Grid>

                                    <Separator Margin="0,0,0,12" />

                                    <!-- Start minimized -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Start minimized to tray" FontWeight="SemiBold" />
                                            <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       Text="Bansa launches hidden in the tray and only shows on hotkey or tray click." />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Style="{StaticResource ThemeToggle}"
                                                      x:Name="StartMinimizedToggle"
                                                      Click="OnStartMinimizedToggleClick" />
                                    </Grid>

                                    <Separator Margin="0,0,0,12" />

                                    <!-- Minimize on close -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Minimize to tray on close" FontWeight="SemiBold" />
                                            <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       Text="Pressing × sends Bansa to the system tray instead of exiting. Use Quit in the tray menu to close fully." />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Style="{StaticResource ThemeToggle}"
                                                      x:Name="MinimizeOnCloseToggle"
                                                      Click="OnMinimizeOnCloseToggleClick" />
                                    </Grid>

                                    <Separator Margin="0,0,0,12" />

                                    <!-- Show tray icon -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Show tray icon" FontWeight="SemiBold" />
                                            <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       Text="Display the Bansa icon in the system tray. Disabling also removes the tray popup." />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" Style="{StaticResource ThemeToggle}"
                                                      x:Name="ShowTrayIconToggle"
                                                      Click="OnShowTrayIconToggleClick" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Settings backup: export / import -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Settings backup" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,14"
                                               Text="Export your full configuration to a JSON file — limits, profiles, colors, ping targets, and all preferences. Import to restore a backup or transfer settings to another machine." />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Export settings…" Padding="14,7" Margin="0,0,10,0"
                                                Click="OnExportSettings" />
                                        <Button Content="Import settings…" Padding="14,7"
                                                Click="OnImportSettings" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- System changes -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="System changes" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,10"
                                               Text="Bansa makes only reversible changes — Defender Firewall rules, QoS policies, and a SQLite history file in %LocalAppData%\Bansa\." />
                                    <Button Content="Clean up — remove all Bansa changes"
                                            Command="{Binding RunCleanupCommand}"
                                            Style="{StaticResource DangerButton}"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- ══ NETWORK tab: Limit profiles · Global cap · Connection speed · Ping · Speed test ══ -->
                        <StackPanel x:Name="SettingsTabNetwork" Visibility="Collapsed">

                            <!-- Limit Profiles -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Limit Profiles" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,16"
                                               Text="Create named presets for bandwidth limits. These appear as quick-apply buttons in the limit window." />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ProfileNameBox" Grid.Column="0" />
                                        <TextBox x:Name="ProfileUpBox"   Grid.Column="2" Text="0" />
                                        <TextBox x:Name="ProfileDownBox" Grid.Column="4" Text="0" />
                                        <Button  Grid.Column="6" Content="Add" Padding="14,6"
                                                 Style="{StaticResource AccentButton}" Click="OnAddProfile" />
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="NAME" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Grid.Column="1" Text="UP KB/s" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Grid.Column="2" Text="DOWN KB/s" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" />
                                    </Grid>
                                    <ItemsControl x:Name="ProfilesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding UploadKbps}" VerticalAlignment="Center"
                                                               FontFamily="{StaticResource RobotoMonoFamily}" Foreground="{DynamicResource SubtleTextBrush}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding DownloadKbps}" VerticalAlignment="Center"
                                                               FontFamily="{StaticResource RobotoMonoFamily}" Foreground="{DynamicResource SubtleTextBrush}" />
                                                    <Button Grid.Column="3" Content="&#x270E;" Padding="6,2" FontSize="12"
                                                            Foreground="{DynamicResource AccentBrush}"
                                                            Click="OnEditProfileClick" Margin="0,0,4,0" />
                                                    <Button Grid.Column="4" Content="&#x2715;" Padding="6,2" FontSize="10"
                                                            Foreground="{DynamicResource DangerBrush}"
                                                            Tag="{Binding Name}" Click="OnRemoveProfile" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Global Upload Cap -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Global upload cap" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                                        <ToggleButton Grid.Column="1" Style="{StaticResource ThemeToggle}"
                                                      IsChecked="{Binding IsGlobalUploadCapEnabled}"
                                                      ToolTip="Enable or disable the cap without losing the value below." />
                                    </Grid>

                                    <!-- Summary — always visible -->
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,4"
                                               Text="Sets a system-wide upload ceiling to prevent buffer bloat. Recommended: ~70% of your upload speed (e.g. 700 KB/s for a 1 MB/s line) — even when your router has QoS enabled." />

                                    <!-- Read more toggle -->
                                    <ToggleButton x:Name="UploadCapReadMoreBtn" HorizontalAlignment="Left" Margin="0,2,0,10">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Content"          Value="Read more ↓" />
                                                <Setter Property="Background"       Value="Transparent" />
                                                <Setter Property="BorderThickness"  Value="0" />
                                                <Setter Property="Padding"          Value="0" />
                                                <Setter Property="Cursor"           Value="Hand" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <TextBlock Text="{TemplateBinding Content}"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       FontSize="11" Cursor="Hand" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Content" Value="Read less ↑" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>

                                    <!-- Expanded explanation -->
                                    <Border Visibility="{Binding IsChecked, ElementName=UploadCapReadMoreBtn, Converter={StaticResource BoolToVis}}"
                                            Background="{DynamicResource PanelAltBrush}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                                                   Text="Router QoS limits throughput but not queue depth — packets can pile up in the modem's hardware buffer before the router's shaper acts on them, causing latency spikes even under the rate limit. Consumer QoS also uses priority bands rather than true Active Queue Management (like CAKE or fq_codel), so short bursts still build up momentary queues. Setting your cap to ~70% of your line speed leaves enough headroom that neither the router queue nor the modem buffer has a chance to fill — which is what actually eliminates jitter, rather than just capping peak speed." />
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBox Width="110" Text="{Binding GlobalUploadCapKBs, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="KB/s" VerticalAlignment="Center" Margin="6,0,16,0"
                                                   Foreground="{DynamicResource SubtleTextBrush}" />
                                        <Button Content="Apply" Command="{Binding ApplyGlobalUploadCapCommand}"
                                                Style="{StaticResource AccentButton}" Padding="12,5" Margin="0,0,8,0" />
                                        <Button Content="Clear" Padding="12,5" Click="OnClearGlobalCap" />
                                    </StackPanel>
                                    <TextBlock Text="0 = no cap. Use the switch above to pause the cap without losing this value. Changes take effect immediately and survive reboot." FontSize="11"
                                               TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                                    <!-- QoS warning banner -->
                                    <Border Visibility="{Binding QosWarningVisible, Converter={StaticResource BoolToVis}}"
                                            Background="#22F59E0B" BorderBrush="#55F59E0B" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10" Margin="0,12,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="&#x26A0;" FontSize="15" Foreground="#F59E0B"
                                                       VerticalAlignment="Top" Margin="0,1,10,6" />
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding QosWarning}" TextWrapping="Wrap"
                                                       FontSize="11" Foreground="#F59E0B" Margin="0,0,0,8" />
                                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Open Network Connections" Padding="10,5" Margin="0,0,8,0"
                                                        Click="OnOpenNetworkConnections" />
                                                <Button Content="Re-check" Padding="10,5"
                                                        Command="{Binding RefreshQosStatusCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Connection Speed -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Connection Speed" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <RadioButton x:Name="SpeedUnitMbpsRadio" GroupName="SpeedUnit"
                                                         Content="Mbps" IsChecked="True"
                                                         Click="OnSpeedUnitChanged" Margin="0,0,12,0" />
                                            <RadioButton x:Name="SpeedUnitGbpsRadio" GroupName="SpeedUnit"
                                                         Content="Gbps" Click="OnSpeedUnitChanged" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,16"
                                               Text="Enter your ISP speeds. Bansa uses these to generate contextual bandwidth limit suggestions when you throttle a specific app." />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="↑ UPLOAD" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ChartUpBrush}" Margin="0,0,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="ConnectionUploadBox" Text="0" />
                                                <TextBlock x:Name="SpeedUnitLabel" Grid.Column="1" Text="Mbps"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="↓ DOWNLOAD" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ChartDownBrush}" Margin="0,0,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="ConnectionDownloadBox" Text="0" />
                                                <TextBlock Grid.Column="1" Text="{Binding ElementName=SpeedUnitLabel, Path=Text}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                    <Button Content="Save" HorizontalAlignment="Left" Margin="0,16,0,0"
                                            Padding="20,8" Style="{StaticResource AccentButton}"
                                            Click="OnSaveConnectionSpeed" />
                                </StackPanel>
                            </Border>

                            <!-- Ping Monitor -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Ping Monitor" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,14"
                                               Text="Select a target to monitor latency. Labels replace the target address in the sidebar. Selecting a target and clicking Set active applies it immediately." />
                                    <TextBlock Text="Select target" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <ComboBox x:Name="PingTargetCombo" Width="260" Margin="0,0,10,0"
                                                  SelectionChanged="OnPingTargetSelectionChanged" />
                                        <Button Content="Set active" Padding="10,5" Click="OnSetPingTarget" />
                                    </StackPanel>
                                    <TextBlock Text="Display label" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <TextBox x:Name="PingLabelBox" Width="260" Margin="0,0,10,0" />
                                        <Button Content="Save label" Padding="10,5" Click="OnSavePingLabel" />
                                    </StackPanel>
                                    <TextBlock Text="Add custom target" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="NewPingTargetBox" Width="200" Margin="0,0,8,0" />
                                        <Button Content="Add &amp; switch" Padding="10,5" Margin="0,0,8,0" Click="OnAddPingTarget" />
                                        <Button Content="Remove selected" Padding="10,5" Click="OnRemovePingTarget" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Verify limits (Speed Test) -->
                            <views:SpeedTestView x:Name="SpeedPanel" />

                        </StackPanel>

                        <!-- ══ APPEARANCE tab: Theme · Colors ══ -->
                        <StackPanel x:Name="SettingsTabAppearance" Visibility="Collapsed">

                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Dark theme" VerticalAlignment="Center" />
                                        <ToggleButton Grid.Column="1" Style="{StaticResource ThemeToggle}"
                                                      IsChecked="{Binding IsDarkTheme, Mode=OneWay}"
                                                      Click="OnThemeToggleClick" />
                                    </Grid>
                                    <CheckBox Content="Use Windows accent color"
                                              IsChecked="{Binding UseWindowsAccent}" />
                                </StackPanel>
                            </Border>

                            <!-- Network graph colors -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Network Graph" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,10"
                                               TextWrapping="Wrap" Text="Colors for the live bandwidth graph. Tray icon bars follow these colors." />
                                    <TextBlock Text="Download" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,4,0,4" />
                                    <ItemsControl x:Name="DownGraphSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <TextBlock Text="Upload" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,10,0,4" />
                                    <ItemsControl x:Name="UpGraphSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Hardware chip colors -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Hardware" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,10"
                                               TextWrapping="Wrap" Text="Colors for CPU, GPU and RAM cards and graphs." />
                                    <TextBlock Text="CPU" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,4,0,4" />
                                    <ItemsControl x:Name="CpuColorSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <TextBlock Text="GPU" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,10,0,4" />
                                    <ItemsControl x:Name="GpuColorSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <TextBlock Text="RAM" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,10,0,4" />
                                    <ItemsControl x:Name="RamColorSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Gradient colors -->
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Gradient Indicators" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                    <TextBlock Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,10"
                                               TextWrapping="Wrap" Text="Start and end colors for temperature and ping heat gradients." />
                                    <TextBlock Text="Temperature — cool" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,4,0,4" />
                                    <ItemsControl x:Name="TempColdSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <TextBlock Text="Temperature — hot" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,10,0,4" />
                                    <ItemsControl x:Name="TempHotSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <TextBlock Text="Ping — good" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,10,0,4" />
                                    <ItemsControl x:Name="PingGoodSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <TextBlock Text="Ping — bad" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,10,0,4" />
                                    <ItemsControl x:Name="PingBadSwatches">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- ══ GAMING MODE tab ══ -->
                        <StackPanel x:Name="SettingsTabGamingMode" Visibility="Collapsed">

                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Gaming Mode profiles" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,14"
                                               Text="When Gaming Mode is active, these per-app limits are applied automatically. Use this to throttle background apps (Spotify, Discord) so they don't compete with your game. Apps not listed are unaffected." />

                                    <!-- Column headers -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="App" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Grid.Column="1" Text="Quick profile" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="Upload KB/s" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="Down KB/s" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" />
                                    </Grid>

                                    <!-- Profile rows -->
                                    <ItemsControl x:Name="GamingModeProfilesControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="32" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding AppName}" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding ExePath}" />
                                                    <ComboBox Grid.Column="1" Margin="4,0"
                                                              ItemsSource="{Binding AvailableLimitProfiles, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              DisplayMemberPath="Name"
                                                              Tag="{Binding ExePath}"
                                                              SelectionChanged="OnGamingModeQuickProfileSelected" />
                                                    <TextBox Grid.Column="2" Margin="4,0" HorizontalContentAlignment="Center"
                                                             Text="{Binding UploadKBs}"
                                                             Tag="{Binding ExePath}"
                                                             LostFocus="OnGamingModeUploadLostFocus" />
                                                    <TextBox Grid.Column="3" Margin="4,0" HorizontalContentAlignment="Center"
                                                             Text="{Binding DownloadKBs}"
                                                             Tag="{Binding ExePath}"
                                                             LostFocus="OnGamingModeDownloadLostFocus" />
                                                    <Button Grid.Column="4" Content="×" FontSize="12"
                                                            Tag="{Binding ExePath}"
                                                            Click="OnRemoveGamingModeProfile"
                                                            Foreground="{DynamicResource DangerBrush}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="4,2" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty state -->
                                    <TextBlock x:Name="GamingModeEmptyText"
                                               Text="No profiles yet. Add apps below."
                                               FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,4,0,0" Visibility="Collapsed" />

                                    <!-- Divider -->
                                    <Border Height="1" Background="{DynamicResource MutedTextBrush}" Opacity="0.2" Margin="0,14,0,14" />

                                    <!-- Add app section -->
                                    <TextBlock Text="Add app" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <!-- TextBox + × button + anchored results popup -->
                                        <Grid Width="220" Margin="0,0,8,0">
                                            <TextBox x:Name="GamingModeSearchBox"
                                                     Padding="6,4,26,4"
                                                     TextChanged="OnGamingModeSearchTextChanged"
                                                     GotFocus="OnGamingModeSearchGotFocus" />
                                            <Button x:Name="GamingModeClearBtn"
                                                    Content="×" FontSize="12"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource MutedTextBrush}"
                                                    Padding="6,2" Margin="0,0,1,0"
                                                    Visibility="Collapsed" Cursor="Hand"
                                                    Click="OnGamingModeSearchClear" />
                                            <Popup x:Name="GamingModeSearchPopup"
                                                   PlacementTarget="{Binding ElementName=GamingModeSearchBox}"
                                                   Placement="Bottom" StaysOpen="False">
                                                <Border Background="{DynamicResource PanelAltBrush}"
                                                        BorderBrush="{DynamicResource MutedTextBrush}"
                                                        BorderThickness="1" CornerRadius="0,0,4,4">
                                                    <ListBox x:Name="GamingModeResultsList"
                                                             DisplayMemberPath="Name"
                                                             MaxHeight="160" MinWidth="218"
                                                             BorderThickness="0" Background="Transparent"
                                                             SelectionChanged="OnGamingModeResultSelected" />
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        <Button Content="Add to profile" Padding="12,5"
                                                Style="{StaticResource AccentButton}"
                                                Click="OnAddGamingModeApp" />
                                    </StackPanel>
                                    <TextBlock FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Text="Type to filter. Launch the app first if it doesn't appear. Set 0 for no limit on that direction." />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- HARDWARE MONITOR -->
                <ScrollViewer x:Name="HardwareMonitorPanel" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,16">

                        <!-- Title row -->
                        <Grid Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Hardware" FontSize="26" FontWeight="Bold" />
                                <TextBlock Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0"
                                           Text="CPU · GPU · Memory  —  refreshes every 2 s via LibreHardwareMonitor" />
                            </StackPanel>
                            <!-- Refresh indicator dot — pulses green each time data arrives -->
                            <Ellipse x:Name="HwRefreshDot"
                                     Width="8" Height="8"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Fill="{DynamicResource SuccessBrush}" Opacity="0.35"
                                     ToolTip="Refreshing every 2 s" />
                        </Grid>

                        <!-- ══ Cards Grid (3 equal columns with 14-px gutters) ══ -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- ── CPU card ── -->
                            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,0,14" Padding="22,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Background="{DynamicResource AccentMutedBrush}" CornerRadius="10"
                                                Width="30" Height="30" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE950;"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="15" Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock x:Name="CpuCardName" Text="—"
                                                       FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="170" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Big temperature + min/avg/max -->
                                    <Grid Grid.Row="1" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="CpuPct"
                                                       Text="—" FontSize="42" FontWeight="Bold"
                                                       Padding="0,4"
                                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource ChartCpuBrush}" />
                                            <TextBlock x:Name="CpuTempSign" Text="°C" FontSize="20" FontWeight="Bold"
                                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource ChartCpuBrush}"
                                                       VerticalAlignment="Bottom" Margin="3,0,0,10" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Margin="0,0,0,12">
                                            <TextBlock x:Name="CpuStatMax" Text="max —°"
                                                       FontSize="13" FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource SubtleTextBrush}" />
                                            <TextBlock x:Name="CpuStatAvg" Text="avg —°"
                                                       FontSize="13" FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock x:Name="CpuStatMin" Text="min —°"
                                                       FontSize="13" FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource SubtleTextBrush}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Progress bar -->
                                    <ProgressBar x:Name="CpuUsageBar" Grid.Row="2"
                                                 Style="{StaticResource CardProgress}"
                                                 Foreground="{DynamicResource ChartCpuBrush}"
                                                 Margin="0,0,0,16" />

                                    <!-- Stats row: Load | Freq -->
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="LOAD" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,3" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="CpuLoadLabel" Text="—"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           FontSize="18" FontWeight="SemiBold" />
                                                <TextBlock Text="%" FontSize="10" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,3" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="FREQ" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,3" />
                                            <TextBlock x:Name="CpuFreqLabel" Text="—"
                                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- CPU temperature sparkline (60 × 2s ≈ 2 min) -->
                                    <Border Grid.Row="5" Margin="0,14,0,0"
                                            Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="8,6">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="TEMP °C" FontSize="8" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock x:Name="CpuTempChartMax" FontSize="8"
                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <Grid Height="70">
                                                <Canvas x:Name="CpuTempChart" ClipToBounds="True" />
                                                <Canvas x:Name="CpuTempOverlay" ClipToBounds="True" Background="Transparent"
                                                        MouseMove="OnCpuChartMouseMove" MouseLeave="OnHwChartMouseLeave" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ── GPU card ── -->
                            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,0,14" Padding="22,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Background="#20F39C12" CornerRadius="10"
                                                Width="30" Height="30" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE7F4;"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="15" Foreground="{DynamicResource ChartUpBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="GPU" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock x:Name="GpuCardName" Text="—"
                                                       FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="170" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Big temperature + min/avg/max -->
                                    <Grid Grid.Row="1" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="GpuPct"
                                                       Text="—" FontSize="42" FontWeight="Bold"
                                                       Padding="0,4"
                                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource ChartGpuBrush}" />
                                            <TextBlock x:Name="GpuTempSign" Text="°C" FontSize="20" FontWeight="Bold"
                                                       FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource ChartGpuBrush}"
                                                       VerticalAlignment="Bottom" Margin="3,0,0,10" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Margin="0,0,0,12">
                                            <TextBlock x:Name="GpuStatMax" Text="max —°"
                                                       FontSize="13" FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource SubtleTextBrush}" />
                                            <TextBlock x:Name="GpuStatAvg" Text="avg —°"
                                                       FontSize="13" FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock x:Name="GpuStatMin" Text="min —°"
                                                       FontSize="13" FontFamily="{StaticResource RobotoMonoFamily}"
                                                       Foreground="{DynamicResource SubtleTextBrush}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- GPU usage bar -->
                                    <ProgressBar x:Name="GpuUsageBar" Grid.Row="2"
                                                 Style="{StaticResource CardProgress}"
                                                 Foreground="{DynamicResource ChartGpuBrush}"
                                                 Margin="0,0,0,8" />

                                    <!-- VRAM sub-row (collapsed until data arrives) -->
                                    <StackPanel x:Name="GpuVramSection" Grid.Row="3" Margin="0,0,0,8"
                                                Visibility="Collapsed">
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="VRAM" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock x:Name="GpuVramText" Text="" FontSize="9"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <ProgressBar x:Name="GpuVramBar" Style="{StaticResource MiniProgress}"
                                                     Foreground="#CC7733" Height="4" />
                                    </StackPanel>

                                    <!-- Stats row: Load only (temp is the big number above) -->
                                    <Grid Grid.Row="4" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="LOAD" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,3" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="GpuLoadLabel" Text="—"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           FontSize="18" FontWeight="SemiBold" />
                                                <TextBlock Text="%" FontSize="10" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,3" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Clocks + Fan row (visible only when sensor data exists) -->
                                    <Grid x:Name="GpuFreqFanRow" Grid.Row="5"
                                          Margin="0,14,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Clocks column -->
                                        <StackPanel>
                                            <TextBlock Text="CLOCKS" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4" />
                                            <TextBlock x:Name="GpuCoreMHzText" Text="Core —"
                                                       FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock x:Name="GpuMemMHzText" Text="Mem —"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>

                                        <!-- Power draw column -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="POWER DRAW" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4" />
                                            <TextBlock x:Name="GpuFanRpmText" Text="— RPM"
                                                       FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock x:Name="GpuFanPctText" Text=""
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- GPU temperature sparkline -->
                                    <Border Grid.Row="7" Margin="0,14,0,0"
                                            Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="8,6">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="TEMP °C" FontSize="8" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock x:Name="GpuTempChartMax" FontSize="8"
                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <Grid Height="70">
                                                <Canvas x:Name="GpuTempChart" ClipToBounds="True" />
                                                <Canvas x:Name="GpuTempOverlay" ClipToBounds="True" Background="Transparent"
                                                        MouseMove="OnGpuChartMouseMove" MouseLeave="OnHwChartMouseLeave" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ── RAM card ── -->
                            <Border Grid.Column="4" Style="{StaticResource Card}" Margin="0,0,0,14" Padding="22,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Background="#203DBA6F" CornerRadius="10"
                                                Width="30" Height="30" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE179;"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="15" Foreground="{DynamicResource SuccessBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="RAM" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock x:Name="RamCardSubtitle" Text="System Memory"
                                                       FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Used GB (big) -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock x:Name="RamUsedText"
                                                   Text="—" FontSize="42" FontWeight="Bold"
                                                   Padding="0,4"
                                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Foreground="{DynamicResource SuccessBrush}" />
                                        <TextBlock Text="GB" FontSize="20" FontWeight="Bold"
                                                   FontFamily="{StaticResource RobotoMonoFamily}"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   VerticalAlignment="Bottom" Margin="4,0,0,10" />
                                    </StackPanel>
                                    <TextBlock x:Name="RamTotalText" Grid.Row="2"
                                               Text="" FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,0,0,10" />

                                    <!-- RAM usage bar -->
                                    <ProgressBar x:Name="RamUsageBar" Grid.Row="3"
                                                 Style="{StaticResource CardProgress}"
                                                 Foreground="{DynamicResource SuccessBrush}"
                                                 Margin="0,0,0,16" />

                                    <!-- Stats row: Used % | Available | Speed -->
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="USED %" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,3" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="RamPct" Text="—"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           FontSize="18" FontWeight="SemiBold" />
                                                <TextBlock Text="%" FontSize="10" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,3" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="AVAILABLE" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,3" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="RamFreeText" Text="—"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           FontSize="18" FontWeight="SemiBold" />
                                                <TextBlock Text="GB" FontSize="10" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Bottom" Margin="2,0,0,3" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="SPEED" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,3" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="RamSpeedLabel" Text="—"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text=" MHz" FontSize="9" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource RobotoMonoFamily}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Bottom" Margin="1,0,0,3" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- RAM usage % sparkline -->
                                    <Border Grid.Row="6" Margin="0,14,0,0"
                                            Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="8,6">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="USAGE %" FontSize="8" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock x:Name="RamUsageChartMax" FontSize="8"
                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <Grid Height="70">
                                                <Canvas x:Name="RamUsageChart" ClipToBounds="True" />
                                                <Canvas x:Name="RamUsageOverlay" ClipToBounds="True" Background="Transparent"
                                                        MouseMove="OnRamChartMouseMove" MouseLeave="OnHwChartMouseLeave" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                        </Grid>

                        <!-- ── System Info card (Motherboard + BIOS) ── -->
                        <Border x:Name="SystemInfoCard" Margin="0,0,0,14"
                                Style="{StaticResource Card}" Padding="22,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Motherboard -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="MOTHERBOARD" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4" />
                                    <TextBlock x:Name="MoboNameText" Text="—"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- BIOS -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="BIOS" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4" />
                                    <TextBlock x:Name="BiosVersionText" Text="—"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── No-sensor notice ── -->
                        <Border x:Name="HwNoDataNotice" Visibility="Collapsed"
                                Background="{DynamicResource PanelAltBrush}" CornerRadius="8"
                                Padding="16,12" Margin="0,4,0,0" MaxWidth="520" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,10,0"
                                           Foreground="{DynamicResource WarningBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock TextWrapping="Wrap" MaxWidth="440"
                                           Foreground="{DynamicResource SubtleTextBrush}" FontSize="12">
                                    Hardware sensor data is unavailable — LibreHardwareMonitor
                                    could not read CPU or GPU sensors on this system.
                                    Bansa must run as Administrator for sensor access.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>

        <!-- ═════════════════ Status bar ═════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,6">
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SubtleTextBrush}" />
        </Border>
    </Grid>
</Window>
